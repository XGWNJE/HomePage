{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.codex-journal/schemas/exchange-package.schema.json",
  "title": "HumanAgencyExchangePackage",
  "description": "A public-safe, versioned package exchanged with HomePage.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "package_version", "package_id", "approval_status", "generated_at", "entries", "content_hash"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "package_version": { "const": 1 },
    "package_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$" },
    "approval_status": { "enum": ["approved-preview", "approved-publish"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" },
      "minItems": 1
    },
    "content_hash": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "stringList": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 1500 },
      "uniqueItems": true
    },
    "publicEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": { "type": "string", "minLength": 1, "maxLength": 300 },
        "url": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "slug",
        "revision",
        "kind",
        "language",
        "cognition_status",
        "title",
        "core_question",
        "human_gain",
        "mental_model",
        "delegable_capabilities",
        "retained_capabilities",
        "transfer_scenarios",
        "evidence",
        "open_questions",
        "body_markdown",
        "related_blog_groups",
        "entry_hash"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,127}$" },
        "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 120 },
        "revision": { "type": "integer", "minimum": 1 },
        "kind": { "enum": ["cognitive-map", "case-study", "research-question", "deep-article"] },
        "language": { "enum": ["zh-CN", "en"] },
        "cognition_status": { "enum": ["understood", "researching", "unresolved"] },
        "title": { "type": "string", "minLength": 1, "maxLength": 180 },
        "core_question": { "type": "string", "minLength": 1, "maxLength": 500 },
        "human_gain": { "$ref": "#/$defs/stringList" },
        "mental_model": { "type": "string", "minLength": 1, "maxLength": 6000 },
        "delegable_capabilities": { "$ref": "#/$defs/stringList" },
        "retained_capabilities": { "$ref": "#/$defs/stringList" },
        "transfer_scenarios": { "$ref": "#/$defs/stringList" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/publicEvidence" },
          "uniqueItems": true
        },
        "open_questions": { "$ref": "#/$defs/stringList" },
        "body_markdown": { "type": "string", "minLength": 1, "maxLength": 50000 },
        "related_blog_groups": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 120 },
          "uniqueItems": true
        },
        "entry_hash": { "$ref": "#/$defs/hash" }
      }
    }
  }
}
