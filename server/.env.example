# Copy these names into the protected service environment file outside the repository.
# Generate independent high-entropy values for every secret. Never commit populated values.
NODE_ENV=production
HOST=
PORT=
HOMEPAGE_API_DATA_DIR=
DATABASE_PATH=
BASE_URL=
FRONTEND_URL=
ALLOWED_ORIGINS=
SESSION_SECRET=
SESSION_TTL_SECONDS=
DEV_LOGIN=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_TOKEN=
ADMIN_GITHUB_LOGINS=
ADMIN_EMAILS=
UPLOAD_DIR=
UPLOAD_PUBLIC_BASE_URL=
CONTACT_TO_EMAIL=
SENDMAIL_PATH=
ENABLE_SENDMAIL=
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_EXPECTED_HOSTNAME=
SERVICE_VERSION=
SERVICE_REVISION=
SUBSCRIPTION_ACCESS_ENABLED=false
SUBSCRIPTION_ACCESS_REGISTRY=/var/lib/vps-proxies-subscription/access/homepage-admin.v1.json
# Production unlock uses the configured GitHub OAuth provider and a host-only
# HttpOnly sensitive-session cookie. The TTL is hard-bounded to 60..300 seconds.
SUBSCRIPTION_ACCESS_TTL_SECONDS=300
# Local no-secret fixture only. Production startup rejects this flag.
SUBSCRIPTION_ACCESS_FIXTURE=false
SUBSCRIPTION_ACCESS_FIXTURE_QR=
