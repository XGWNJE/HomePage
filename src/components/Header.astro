---
import { GITHUB_URL, SITE_TITLE } from '../consts';
import { DEFAULT_UI_LANG, getUiText, uiText } from '../data/i18n';
import { getNavLinks } from '../data/navLinks';
import BrandMark from './BrandMark.astro';
import HeaderLink from './HeaderLink.astro';
import LoginModal from './LoginModal.astro';
import SettingsModal from './SettingsModal.astro';

/*
 * Global site header:
 * - provides primary navigation on desktop
 * - exposes mobile trigger hooks for navigation/TOC drawers
 * - owns theme toggle and social identity actions
 */
interface Props {
	// Enables TOC trigger only for pages that actually provide headings.
	showTocButton?: boolean;
}

const BASE = import.meta.env.BASE_URL;
const AVATAR_URL = `${BASE}image/favicon-192.png`;
const NAV_LINKS = getNavLinks(BASE);
const T = getUiText(DEFAULT_UI_LANG);
const { showTocButton = false } = Astro.props as Props;
---

<header class="site-header sticky top-0 z-50 border-b border-zinc-200/70 bg-zinc-50/72 backdrop-blur-xl transition-colors duration-200 dark:border-zinc-800/80 dark:bg-zinc-950/72">
	<nav class="page-shell flex h-16 items-center justify-between gap-2 sm:gap-4">
		<div class="flex min-w-0 items-center gap-3 md:gap-6">
			<!-- Stable trigger ID consumed by MobileDrawer script. -->
			<button
				type="button"
				id="mobile-menu-button"
				class="header-toolbar-button inline-flex shrink-0 items-center gap-2 px-3 py-2 text-sm font-medium md:hidden max-[360px]:gap-0 max-[360px]:px-2"
				aria-controls="mobile-drawer"
				aria-expanded="false"
				aria-label={T['actions.menu']}
				data-i18n-aria-label="actions.menu"
			>
				<svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
					<path d="M4 6.5A1.5 1.5 0 0 1 5.5 5h13a1.5 1.5 0 1 1 0 3h-13A1.5 1.5 0 0 1 4 6.5Zm0 5.5a1.5 1.5 0 0 1 1.5-1.5h13a1.5 1.5 0 0 1 0 3h-13A1.5 1.5 0 0 1 4 12Zm1.5 4a1.5 1.5 0 1 0 0 3h13a1.5 1.5 0 0 0 0-3h-13Z" />
				</svg>
				<span class="max-[360px]:sr-only" data-i18n="actions.menu">{T['actions.menu']}</span>
			</button>
			<!-- TOC drawer binds to this trigger and only renders on mobile. -->
			{
				showTocButton && (
					<button
						type="button"
						id="toc-menu-button"
						class="header-toolbar-button inline-flex shrink-0 items-center gap-2 px-3 py-2 text-sm font-medium md:hidden max-[360px]:gap-0 max-[360px]:px-2"
						aria-controls="toc-drawer"
						aria-expanded="false"
						aria-label={T['actions.toc']}
						data-i18n-aria-label="actions.toc"
					>
						<svg viewBox="0 0 24 24" class="h-4 w-4 fill-current" aria-hidden="true">
							<path d="M4 6a1 1 0 0 1 1-1h14a1 1 0 1 1 0 2H5a1 1 0 0 1-1-1Zm0 6a1 1 0 0 1 1-1h14a1 1 0 1 1 0 2H5a1 1 0 0 1-1-1Zm1 5a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2H5Z" />
						</svg>
						<span class="max-[360px]:sr-only" data-i18n="actions.toc">{T['actions.toc']}</span>
					</button>
				)
			}
			<a href={`${BASE}`} class="group hidden no-underline md:inline" aria-label={SITE_TITLE}>
				<span class="brand-wordmark inline-flex items-center gap-1.5 rounded-full border border-zinc-200/75 bg-white/70 px-3 py-1.5 text-zinc-800 shadow-[0_8px_20px_rgba(15,23,42,0.04)] backdrop-blur-md transition-all duration-200 group-hover:border-zinc-300/95 group-hover:bg-white/92 group-hover:text-zinc-950 dark:border-zinc-700/75 dark:bg-zinc-900/68 dark:text-zinc-100 dark:shadow-[0_8px_18px_rgba(0,0,0,0.16)] dark:group-hover:border-zinc-500/95 dark:group-hover:bg-zinc-800/92">
					<BrandMark class="h-[1.2em] -ml-0.5" />
					<span class="text-[1.06rem] leading-none">XGWNJE</span>
					<span class="text-[1.06rem] italic leading-none text-zinc-500 transition-colors duration-200 group-hover:text-zinc-700 dark:text-zinc-400 dark:group-hover:text-zinc-200">Index</span>
				</span>
			</a>
			<div class="hidden items-center gap-1 text-sm md:flex">
				{
					NAV_LINKS.map((link) => (
						<HeaderLink href={link.href}><span data-i18n={link.labelKey}>{link.label}</span></HeaderLink>
					))
				}
			</div>
		</div>
		<div id="header-actions" class="flex min-w-0 shrink items-center justify-end gap-1.5 sm:gap-2">
			<div
				class="ui-lang-toggle inline-flex h-9 shrink-0 items-center rounded-xl border border-zinc-200/80 bg-white/75 p-1 shadow-[0_8px_20px_rgba(15,23,42,0.05)] backdrop-blur-md dark:border-zinc-700/80 dark:bg-zinc-900/72"
				aria-label={T['language.switch']}
				data-i18n-aria-label="language.switch"
			>
				<button type="button" class="ui-lang-option" data-ui-lang-option="cn" aria-pressed="true">
					<span data-i18n="language.chineseShort">{T['language.chineseShort']}</span>
				</button>
				<button type="button" class="ui-lang-option" data-ui-lang-option="en" aria-pressed="false">
					<span data-i18n="language.englishShort">{T['language.englishShort']}</span>
				</button>
			</div>
			<!-- RSS Dropdown -->
			<div class="relative max-[430px]:hidden" id="rss-dropdown">
				<button
					type="button"
					id="rss-button"
					class="header-toolbar-icon icon-button inline-flex items-center justify-center"
					aria-label={T['rss.label']}
					aria-expanded="false"
					aria-haspopup="true"
					data-i18n-aria-label="rss.label"
				>
					<svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
						<path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z" />
					</svg>
				</button>
				<div
					id="rss-menu"
					class="absolute right-0 top-full z-50 mt-2 hidden w-36 rounded-xl border border-zinc-200/80 bg-white/92 py-1.5 shadow-[0_18px_40px_rgba(15,23,42,0.14)] dark:border-zinc-700/80 dark:bg-zinc-900/92"
					role="menu"
				>
					<a
						href={`${BASE}feed.xml`}
						class="flex items-center gap-2 px-3 py-2 text-sm text-zinc-700 transition-colors hover:bg-zinc-100/90 dark:text-zinc-300 dark:hover:bg-zinc-800"
						role="menuitem"
					>
						<svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z" />
						</svg>
						<span data-i18n="rss.all">{T['rss.all']}</span>
					</a>
					<a
						href={`${BASE}feed-zh.xml`}
						class="flex items-center gap-2 px-3 py-2 text-sm text-zinc-700 transition-colors hover:bg-zinc-100/90 dark:text-zinc-300 dark:hover:bg-zinc-800"
						role="menuitem"
					>
						<svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z" />
						</svg>
						<span data-i18n="rss.zh">{T['rss.zh']}</span>
					</a>
					<a
						href={`${BASE}feed-en.xml`}
						class="flex items-center gap-2 px-3 py-2 text-sm text-zinc-700 transition-colors hover:bg-zinc-100/90 dark:text-zinc-300 dark:hover:bg-zinc-800"
						role="menuitem"
					>
						<svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
							<path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z" />
						</svg>
						<span data-i18n="rss.en">{T['rss.en']}</span>
					</a>
				</div>
			</div>
			<div class="header-toolbar-group hidden md:inline-flex">
				<a
					href={GITHUB_URL}
					target="_blank"
					rel="noreferrer"
					class="header-toolbar-icon icon-button inline-flex items-center justify-center"
					aria-label="GitHub"
				>
					<svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
						<path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.523 2 12 2z" />
					</svg>
					<span class="sr-only">GitHub</span>
				</a>

				<button
					type="button"
					id="theme-toggle"
					class="header-toolbar-icon icon-button inline-flex items-center justify-center"
					aria-label={T['theme.toggle']}
					data-i18n-aria-label="theme.toggle"
					title={T['theme.toggle']}
					data-i18n-title="theme.toggle"
				>
					<svg data-theme-icon viewBox="0 0 24 24" class="theme-toggle-glyph h-5 w-5" aria-hidden="true">
						<g data-theme-sun>
							<circle cx="12" cy="12" r="3.7" />
							<path d="M12 2.75v2.1M12 19.15v2.1M4.85 12h-2.1M21.25 12h-2.1M6.95 6.95 5.45 5.45M18.55 18.55l-1.5-1.5M17.05 6.95l1.5-1.5M5.45 18.55l1.5-1.5" />
						</g>
						<g data-theme-moon>
							<path d="M20.1 14.25a7.65 7.65 0 0 1-10.35-10.35 8.15 8.15 0 1 0 10.35 10.35Z" />
							<path d="m17.75 3.75.48 1 .98.48-.98.48-.48.98-.48-.98-.98-.48.98-.48.48-1Z" />
						</g>
					</svg>
					<span class="sr-only" data-i18n="theme.toggle">{T['theme.toggle']}</span>
				</button>

				<!-- Login button (shown when not logged in) -->
				<button type="button" id="auth-button" class="header-toolbar-button hidden h-9 items-center justify-center px-3 text-sm font-medium" data-auth-login>
					<span data-i18n="account.login">{T['account.login']}</span>
				</button>
			</div>

			<a
				id="github-link-mobile"
				href={GITHUB_URL}
				target="_blank"
				rel="noreferrer"
				class="header-toolbar-icon icon-button inline-flex items-center justify-center md:hidden max-[520px]:hidden"
				aria-label="GitHub"
			>
				<svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
					<path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.523 2 12 2z" />
				</svg>
				<span class="sr-only">GitHub</span>
			</a>

			<button
				type="button"
				id="theme-toggle-mobile"
				class="header-toolbar-icon icon-button inline-flex items-center justify-center md:hidden"
				aria-label={T['theme.toggle']}
				data-i18n-aria-label="theme.toggle"
				title={T['theme.toggle']}
				data-i18n-title="theme.toggle"
			>
				<svg data-theme-icon viewBox="0 0 24 24" class="theme-toggle-glyph h-5 w-5" aria-hidden="true">
					<g data-theme-sun>
						<circle cx="12" cy="12" r="3.7" />
						<path d="M12 2.75v2.1M12 19.15v2.1M4.85 12h-2.1M21.25 12h-2.1M6.95 6.95 5.45 5.45M18.55 18.55l-1.5-1.5M17.05 6.95l1.5-1.5M5.45 18.55l1.5-1.5" />
					</g>
					<g data-theme-moon>
						<path d="M20.1 14.25a7.65 7.65 0 0 1-10.35-10.35 8.15 8.15 0 1 0 10.35 10.35Z" />
						<path d="m17.75 3.75.48 1 .98.48-.98.48-.48.98-.48-.98-.98-.48.98-.48.48-1Z" />
					</g>
				</svg>
				<span class="sr-only" data-i18n="theme.toggle">{T['theme.toggle']}</span>
			</button>

			<!-- User dropdown (shown when logged in) -->
			<div id="user-dropdown" class="relative hidden" data-auth-user>
				<button
					type="button"
					id="user-dropdown-button"
					class="flex items-center gap-2 rounded-full border border-zinc-200/85 bg-white/82 p-0.5 shadow-[0_8px_22px_rgba(15,23,42,0.08)] transition-all duration-200 hover:-translate-y-0.5 hover:border-zinc-300 hover:bg-white/95 hover:shadow-[0_12px_26px_rgba(15,23,42,0.12)] dark:border-zinc-700/85 dark:bg-zinc-900/80 dark:shadow-[0_8px_18px_rgba(0,0,0,0.18)] dark:hover:border-zinc-500 dark:hover:bg-zinc-800/95"
					aria-expanded="false"
					aria-haspopup="true"
				>
					<img
						id="user-avatar"
						src={AVATAR_URL}
						alt="User avatar"
						class="h-8 w-8 rounded-full object-cover"
					/>
				</button>
				<div
					id="user-dropdown-menu"
					class="absolute right-0 mt-2 w-56 rounded-2xl border border-zinc-200/80 bg-white/92 py-1.5 shadow-[0_18px_40px_rgba(15,23,42,0.14)] opacity-0 invisible transition-all duration-200 dark:border-zinc-700/80 dark:bg-zinc-900/92"
					role="menu"
				>
					<!-- Header: avatar + username + subtitle -->
					<div class="border-b border-zinc-200/80 px-3 py-3 dark:border-zinc-700/80">
						<div class="flex items-center gap-3">
							<img
								id="dropdown-user-avatar"
								src={AVATAR_URL}
								alt="User avatar"
								class="h-10 w-10 rounded-full object-cover"
							/>
							<div class="min-w-0">
								<p id="user-name" class="text-sm font-medium text-zinc-900 dark:text-zinc-100 truncate">{T['account.user']}</p>
								<p class="text-xs text-zinc-500 dark:text-zinc-400" data-i18n="account.manage">{T['account.manage']}</p>
							</div>
						</div>
					</div>
					<!-- Settings button -->
					<button
						type="button"
						id="settings-button"
						class="mx-1 flex w-[calc(100%-0.5rem)] items-center gap-2 rounded-xl px-3 py-2 text-left text-sm text-zinc-700 transition-colors hover:bg-zinc-100/90 dark:text-zinc-300 dark:hover:bg-zinc-800"
						role="menuitem"
					>
						<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path d="M12 15a3 3 0 100-6 3 3 0 000 6z" />
							<path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z" />
						</svg>
						<span data-i18n="account.settings">{T['account.settings']}</span>
					</button>
					<!-- Footer: Logout -->
					<div class="mt-1 border-t border-zinc-200/80 pb-1 pt-1 dark:border-zinc-700/80">
						<button
							type="button"
							id="logout-button"
							class="mx-1 flex w-[calc(100%-0.5rem)] items-center gap-2 rounded-xl px-3 py-2 text-left text-sm text-red-600 transition-colors hover:bg-zinc-100/90 dark:text-red-400 dark:hover:bg-zinc-800"
							role="menuitem"
						>
							<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
								<path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" />
								<polyline points="16,17 21,12 16,7" />
								<line x1="21" y1="12" x2="9" y2="12" />
							</svg>
							<span data-i18n="account.logout">{T['account.logout']}</span>
						</button>
					</div>
				</div>
			</div>
		</div>
	</nav>
</header>

<LoginModal />
<SettingsModal />

<style is:global>
	.header-toolbar-group {
		height: 2.5rem;
		align-items: center;
		gap: 0.375rem;
		padding: 0.25rem;
		border-radius: 1rem;
		border: 1px solid rgba(228, 228, 231, 0.78);
		background: rgba(255, 255, 255, 0.72);
		box-shadow: 0 10px 28px rgba(15, 23, 42, 0.08);
		backdrop-filter: blur(14px);
	}

	html.dark .header-toolbar-group {
		border-color: rgba(63, 63, 70, 0.8);
		background: rgba(24, 24, 27, 0.72);
		box-shadow: 0 10px 26px rgba(0, 0, 0, 0.22);
	}

	.header-toolbar-button,
	.header-toolbar-icon {
		border-radius: 0.9rem;
		border: 1px solid rgba(228, 228, 231, 0.75);
		background: rgba(255, 255, 255, 0.7);
		color: rgb(82 82 91);
		backdrop-filter: blur(10px);
		box-shadow: 0 6px 16px rgba(15, 23, 42, 0.04);
		transition:
			transform 180ms cubic-bezier(0.22, 1, 0.36, 1),
			background-color 180ms ease,
			border-color 180ms ease,
			color 180ms ease,
			box-shadow 180ms ease;
	}

	html.dark .header-toolbar-button,
	html.dark .header-toolbar-icon {
		border-color: rgba(63, 63, 70, 0.84);
		background: rgba(39, 39, 42, 0.7);
		color: rgb(212 212 216);
		box-shadow: 0 8px 18px rgba(0, 0, 0, 0.16);
	}

	.header-toolbar-button:hover,
	.header-toolbar-icon:hover {
		transform: translateY(-1px);
		background: rgba(255, 255, 255, 0.96);
		border-color: rgba(212, 212, 216, 0.98);
		color: rgb(24 24 27);
		box-shadow: 0 10px 22px rgba(15, 23, 42, 0.1);
	}

	html.dark .header-toolbar-button:hover,
	html.dark .header-toolbar-icon:hover {
		background: rgba(63, 63, 70, 0.96);
		border-color: rgba(113, 113, 122, 1);
		color: rgb(250 250 250);
		box-shadow: 0 10px 22px rgba(0, 0, 0, 0.24);
	}

	.header-toolbar-button:active,
	.header-toolbar-icon:active {
		transform: scale(0.97);
	}

	.header-toolbar-icon {
		height: 2rem;
		width: 2rem;
	}

	.theme-toggle-glyph {
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 1.85;
	}

	.theme-toggle-glyph [data-theme-sun],
	.theme-toggle-glyph [data-theme-moon] {
		transform-box: fill-box;
		transform-origin: center;
		transition:
			opacity 180ms ease,
			transform 240ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.theme-toggle-glyph [data-theme-moon] {
		opacity: 0;
		transform: scale(0.72) rotate(-28deg);
	}

	html.dark .theme-toggle-glyph [data-theme-sun] {
		opacity: 0;
		transform: scale(0.72) rotate(28deg);
	}

	html.dark .theme-toggle-glyph [data-theme-moon] {
		opacity: 1;
		transform: scale(1) rotate(0deg);
	}

	.ui-lang-option {
		display: inline-flex;
		height: 1.75rem;
		min-width: 1.85rem;
		align-items: center;
		justify-content: center;
		border-radius: 0.7rem;
		padding: 0 0.45rem;
		font-size: 0.72rem;
		font-weight: 700;
		line-height: 1;
		color: rgb(113 113 122);
		transition: background-color 160ms ease, color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
	}

	.ui-lang-option:hover {
		color: rgb(24 24 27);
		transform: translateY(-1px);
	}

	html.dark .ui-lang-option {
		color: rgb(161 161 170);
	}

	html.dark .ui-lang-option:hover {
		color: rgb(250 250 250);
	}

	.ui-lang-option.is-active {
		background: rgba(24, 24, 27, 0.92);
		color: rgb(250 250 250);
		box-shadow: 0 6px 16px rgba(15, 23, 42, 0.16);
	}

	html.dark .ui-lang-option.is-active {
		background: rgba(250, 250, 250, 0.94);
		color: rgb(24 24 27);
		box-shadow: 0 6px 16px rgba(255, 255, 255, 0.08);
	}

	@media (max-width: 380px) {
		.ui-lang-toggle {
			height: 2rem;
			padding: 0.1875rem;
			border-radius: 0.8rem;
		}

		.ui-lang-option {
			height: 1.55rem;
			min-width: 1.52rem;
			border-radius: 0.62rem;
			padding: 0 0.32rem;
			font-size: 0.68rem;
		}

		.header-toolbar-icon {
			height: 1.9rem;
			width: 1.9rem;
			border-radius: 0.78rem;
		}
	}

	html:not([data-ui-lang]) [data-i18n-content-lang="en"],
	html[data-ui-lang="cn"] [data-i18n-content-lang="en"],
	html[data-ui-lang="en"] [data-i18n-content-lang="cn"] {
		display: none !important;
	}
</style>

<script is:inline define:vars={{ translations: uiText, defaultUiLang: DEFAULT_UI_LANG }}>
	(() => {
		const storageKey = 'xgwnje.uiLang';
		const hasLang = (value) => Boolean(value && Object.prototype.hasOwnProperty.call(translations, value));
		const getStoredLang = () => {
			try {
				const stored = localStorage.getItem(storageKey);
				return hasLang(stored) ? stored : defaultUiLang;
			} catch {
				return defaultUiLang;
			}
		};
		const getText = (key, lang = getStoredLang()) =>
			translations?.[lang]?.[key] ?? translations?.[defaultUiLang]?.[key] ?? key;

		const setAttrTranslation = (selector, attribute, lang) => {
			document.querySelectorAll(selector).forEach((node) => {
				const key = node.getAttribute(selector.slice(1, -1));
				if (key) node.setAttribute(attribute, getText(key, lang));
			});
		};

		const applyLanguage = (lang = getStoredLang()) => {
			if (!hasLang(lang)) lang = defaultUiLang;
			const root = document.documentElement;
			root.dataset.uiLang = lang;

			document.querySelectorAll('[data-i18n]').forEach((node) => {
				const key = node.getAttribute('data-i18n');
				if (key) node.textContent = getText(key, lang);
			});

			setAttrTranslation('[data-i18n-aria-label]', 'aria-label', lang);
			setAttrTranslation('[data-i18n-placeholder]', 'placeholder', lang);
			setAttrTranslation('[data-i18n-title]', 'title', lang);

			document.querySelectorAll('[data-ui-lang-option]').forEach((button) => {
				const active = button.getAttribute('data-ui-lang-option') === lang;
				button.classList.toggle('is-active', active);
				button.setAttribute('aria-pressed', String(active));
				if (button.dataset.uiLangBound !== 'true') {
					button.dataset.uiLangBound = 'true';
					button.addEventListener('click', () => {
						const nextLang = button.getAttribute('data-ui-lang-option');
						if (!hasLang(nextLang)) return;
						try {
							localStorage.setItem(storageKey, nextLang);
						} catch {}
						applyLanguage(nextLang);
					});
				}
			});

			window.dispatchEvent(new CustomEvent('xgwnje:ui-language', { detail: { lang } }));
		};

		window.__xgwnjeI18n = {
			get lang() {
				return getStoredLang();
			},
			setLang(lang) {
				if (!hasLang(lang)) return;
				try {
					localStorage.setItem(storageKey, lang);
				} catch {}
				applyLanguage(lang);
			},
			apply: applyLanguage,
			text: getText,
		};

		applyLanguage();
		document.addEventListener('astro:page-load', () => applyLanguage());
		document.addEventListener('astro:after-swap', () => applyLanguage());
	})();
</script>

<script is:inline>
	const initAuthButton = async () => {
		const { storeTokenFromHash, getCurrentUser, getAuthToken, logout } = window.__auth || {};
		if (!storeTokenFromHash || !getCurrentUser || !getAuthToken || !logout) {
			setTimeout(initAuthButton, 100);
			return;
		}

		const loginButton = document.getElementById('auth-button');
		const userDropdown = document.getElementById('user-dropdown');
		const userAvatar = document.getElementById('user-avatar');
		const userName = document.getElementById('user-name');
		const userDropdownButton = document.getElementById('user-dropdown-button');
		const userDropdownMenu = document.getElementById('user-dropdown-menu');
		const logoutButton = document.getElementById('logout-button');
		const modal = document.getElementById('login-modal');
		const modalClose = document.getElementById('login-modal-close');
		const dropdownAvatar = document.getElementById('dropdown-user-avatar');
		const settingsButton = document.getElementById('settings-button');
		const fallbackAvatar = '/image/favicon-192.png';

		if (!loginButton || !userDropdown || !userDropdownButton || !userDropdownMenu || !logoutButton || !settingsButton) {
			return;
		}

		const openModal = () => {
			if (!modal) return;
			requestAnimationFrame(() => {
				modal.classList.remove('opacity-0', 'invisible');
				modal.classList.add('opacity-100');
				const content = modal.querySelector('.modal-content');
				if (content) {
					content.classList.remove('scale-95', 'opacity-0');
					content.classList.add('scale-100', 'opacity-100');
				}
				modal.setAttribute('aria-hidden', 'false');
			});
		};

		const closeModal = () => {
			if (!modal) return;
			modal.classList.remove('opacity-100');
			modal.classList.add('opacity-0');
			const content = modal.querySelector('.modal-content');
			if (content) {
				content.classList.remove('scale-100', 'opacity-100');
				content.classList.add('scale-95', 'opacity-0');
			}
			setTimeout(() => modal.classList.add('invisible'), 200);
			modal.setAttribute('aria-hidden', 'true');
		};

		const toggleDropdown = () => {
			if (!userDropdownButton || !userDropdownMenu) return;
			const isExpanded = userDropdownButton.getAttribute('aria-expanded') === 'true';
			userDropdownButton.setAttribute('aria-expanded', String(!isExpanded));
			if (isExpanded) {
				userDropdownMenu.classList.add('opacity-0', 'invisible');
				userDropdownMenu.classList.remove('opacity-100', 'visible');
			} else {
				userDropdownMenu.classList.remove('opacity-0', 'invisible');
				userDropdownMenu.classList.add('opacity-100', 'visible');
			}
		};

		const closeDropdown = () => {
			if (!userDropdownButton || !userDropdownMenu) return;
			userDropdownButton.setAttribute('aria-expanded', 'false');
			userDropdownMenu.classList.add('opacity-0', 'invisible');
			userDropdownMenu.classList.remove('opacity-100', 'visible');
		};

		const applyUserToUi = (user) => {
			const nextAvatar = user?.avatar || fallbackAvatar;
			const nextName = user?.username || 'User';
			if (userAvatar) userAvatar.src = nextAvatar;
			if (userName) userName.textContent = nextName;
			if (dropdownAvatar) dropdownAvatar.src = nextAvatar;
		};

		const showLoginButton = () => {
			loginButton.classList.remove('hidden');
			loginButton.classList.add('inline-flex');
			userDropdown.classList.add('hidden');
			userDropdown.style.display = '';
			closeDropdown();
		};

		const showUserDropdown = () => {
			loginButton.classList.add('hidden');
			loginButton.classList.remove('inline-flex');
			userDropdown.classList.remove('hidden');
			userDropdown.style.display = 'block';
		};

		if (userDropdown.dataset.authBound !== 'true') {
			userDropdown.dataset.authBound = 'true';

			window.addEventListener('blog:user-updated', (event) => {
				const detail = event.detail ?? {};
				applyUserToUi({
					avatar: detail.avatarUrl,
					username: detail.username,
				});
			});

			userDropdownButton.addEventListener('click', (e) => {
				e.stopPropagation();
				toggleDropdown();
			});

			logoutButton.addEventListener('click', async () => {
				closeDropdown();
				await logout();
				window.location.reload();
			});

			settingsButton.addEventListener('click', () => {
				closeDropdown();
				document.getElementById('settings-modal')?.dispatchEvent(new CustomEvent('open-settings'));
			});

			document.addEventListener('click', (e) => {
				if (userDropdown && !userDropdown.contains(e.target)) closeDropdown();
			});
		}

		modal?.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
		modalClose?.addEventListener('click', closeModal);
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && modal && !modal.classList.contains('invisible')) closeModal();
		});

		try {
			storeTokenFromHash();
			const hasToken = Boolean(getAuthToken());

			if (hasToken) {
				showUserDropdown();
				applyUserToUi({
					avatar: userAvatar?.src || fallbackAvatar,
					username: userName?.textContent || 'User',
				});
			}

			const user = await getCurrentUser();

			if (user) {
				showUserDropdown();
				applyUserToUi(user);
			} else {
				showLoginButton();
			}
		} catch (error) {
			console.error('Auth error:', error);
			showLoginButton();
		}

		if (loginButton.dataset.authBound !== 'true') {
			loginButton.dataset.authBound = 'true';
			loginButton.addEventListener('click', openModal);
		}
	};

	initAuthButton();
	document.addEventListener('astro:page-load', initAuthButton);

	const initThemeToggle = () => {
		const buttons = Array.from(document.querySelectorAll('[id="theme-toggle"], [id="theme-toggle-mobile"]'));
		if (!buttons.length) return;

		const root = document.documentElement;
		const storageKey = 'theme';
		const applyStoredTheme = () => {
			const stored = localStorage.getItem(storageKey);
			const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
			const theme = stored === 'dark' || stored === 'light'
				? stored
				: (systemPrefersDark ? 'dark' : 'light');
			root.classList.toggle('dark', theme === 'dark');
			root.dataset.theme = theme;
			// Route swaps restore the static head, so re-sync the browser chrome color.
			if (typeof window.__syncThemeColor === 'function') window.__syncThemeColor(theme === 'dark');
			return theme === 'dark';
		};

		const updateAria = () => {
			const isDark = root.classList.contains('dark');
			buttons.forEach((button) => {
				button.setAttribute('aria-pressed', String(isDark));
				button.dataset.themeState = isDark ? 'dark' : 'light';
			});
		};

		buttons.forEach((button) => {
			if (button.dataset.bound === 'true') return;
			button.dataset.bound = 'true';
			button.addEventListener('click', (event) => {
				const applyTheme = () => {
					const isDark = root.classList.toggle('dark');
					root.dataset.theme = isDark ? 'dark' : 'light';
					localStorage.setItem(storageKey, isDark ? 'dark' : 'light');
					if (typeof window.__syncThemeColor === 'function') window.__syncThemeColor(isDark);
					updateAria();
				};

				const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				if (typeof document.startViewTransition !== 'function' || reducedMotion) {
					applyTheme();
					return;
				}

				// Expand the new theme as a circle from the click point for a tactile switch feel.
				const rect = button.getBoundingClientRect();
				const x = event.clientX || rect.left + rect.width / 2;
				const y = event.clientY || rect.top + rect.height / 2;
				const endRadius = Math.hypot(
					Math.max(x, window.innerWidth - x),
					Math.max(y, window.innerHeight - y)
				);

				root.classList.add('theme-vt');
				const transition = document.startViewTransition(applyTheme);
				transition.ready
					.then(() => {
						document.documentElement.animate(
							{
								clipPath: [
									`circle(0px at ${x}px ${y}px)`,
									`circle(${endRadius}px at ${x}px ${y}px)`,
								],
							},
							{
								duration: 500,
								easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
								pseudoElement: '::view-transition-new(root)',
							}
						);
					})
					.catch(() => {});
				transition.finished
					.catch(() => {})
					.finally(() => root.classList.remove('theme-vt'));
			});
		});

		applyStoredTheme();
		updateAria();
	};

	initThemeToggle();
	// Rebind on client-side navigation because header can be re-rendered by View Transitions.
	document.addEventListener('astro:page-load', initThemeToggle);
	document.addEventListener('astro:after-swap', initThemeToggle);

	// RSS Dropdown
	const initRssDropdown = () => {
		const rssDropdown = document.getElementById('rss-dropdown');
		const rssButton = document.getElementById('rss-button');
		const rssMenu = document.getElementById('rss-menu');

		if (!rssDropdown || !rssButton || !rssMenu) return;

		// Prevent double binding
		if (rssButton.dataset.rssBound === 'true') return;
		rssButton.dataset.rssBound = 'true';

		const toggleDropdown = (e) => {
			e.stopPropagation();
			const isExpanded = rssButton.getAttribute('aria-expanded') === 'true';
			rssButton.setAttribute('aria-expanded', String(!isExpanded));
			if (isExpanded) {
				rssMenu.classList.add('hidden');
			} else {
				rssMenu.classList.remove('hidden');
			}
		};

		const closeDropdown = () => {
			rssButton.setAttribute('aria-expanded', 'false');
			rssMenu.classList.add('hidden');
		};

		// Click to toggle on all devices (mobile-friendly)
		rssButton.addEventListener('click', toggleDropdown);

		// Close when clicking outside
		document.addEventListener('click', (e) => {
			if (!rssDropdown.contains(e.target)) {
				closeDropdown();
			}
		});

		// Close on Escape
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && !rssMenu.classList.contains('hidden')) {
				closeDropdown();
			}
		});
	};

	initRssDropdown();
	document.addEventListener('astro:page-load', initRssDropdown);
	document.addEventListener('astro:after-swap', initRssDropdown);
</script>
