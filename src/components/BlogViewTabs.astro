---
import { DEFAULT_UI_LANG, getUiText } from '../data/i18n';
import { getPublishedPosts } from '../utils/publishedPosts';

type BlogView = 'important' | 'latest' | 'digested' | 'archive';

interface Props {
	current: BlogView;
}

const { current } = Astro.props;
const BASE = import.meta.env.BASE_URL;
const T = getUiText(DEFAULT_UI_LANG);
const hasDigestedPosts = (await getPublishedPosts()).some((post) => post.data.category === '消化');
const tabs: { id: BlogView; href: string; labelKey: 'blog.important' | 'blog.latest' | 'blog.digested' | 'blog.archive'; label: string }[] = [
	{ id: 'important', href: `${BASE}blog/important/`, labelKey: 'blog.important', label: T['blog.important'] },
	{ id: 'latest', href: `${BASE}blog/`, labelKey: 'blog.latest', label: T['blog.latest'] },
	{ id: 'archive', href: `${BASE}blog/archive/`, labelKey: 'blog.archive', label: T['blog.archive'] },
];
if (hasDigestedPosts) {
	tabs.splice(2, 0, { id: 'digested', href: `${BASE}blog/digested/`, labelKey: 'blog.digested', label: T['blog.digested'] });
}
---

<div
	class="view-toggle inline-flex items-center rounded-2xl border border-zinc-200/80 bg-white/75 p-1 shadow-[0_8px_30px_rgba(15,23,42,0.06)] backdrop-blur-md dark:border-zinc-700/80 dark:bg-zinc-900/70"
	role="tablist"
	aria-label={T['blog.viewSwitch']}
	data-i18n-aria-label="blog.viewSwitch"
>
	{tabs.map((tab) => {
		const active = current === tab.id;
		return (
			<a
				href={tab.href}
				class:list={[
					'apple-float-chip relative inline-flex items-center justify-center gap-1.5 rounded-xl px-2 py-2 text-sm font-medium transition-all duration-200 md:gap-2 md:px-3',
					active
						? 'bg-zinc-900/6 text-zinc-900 shadow-[0_6px_18px_rgba(15,23,42,0.08)] dark:bg-white/10 dark:text-white'
						: 'text-zinc-500 hover:text-zinc-700 dark:text-zinc-400 dark:hover:text-zinc-200',
				]}
				role="tab"
				aria-selected={active}
				aria-label={tab.label}
				data-i18n-aria-label={tab.labelKey}
			>
				<span class="apple-float-label">
					{tab.id === 'important' && (
						<svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
						</svg>
					)}
					{tab.id === 'latest' && (
						<svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
						</svg>
					)}
					{tab.id === 'archive' && (
						<svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
						</svg>
					)}
					{tab.id === 'digested' && (
						<svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" d="M5 4.75h10.5A3.5 3.5 0 0 1 19 8.25V19H8.5A3.5 3.5 0 0 1 5 15.5V4.75Z" />
							<path stroke-linecap="round" stroke-linejoin="round" d="M8.5 19A3.5 3.5 0 0 1 5 15.5M9 9h6M9 13h4" />
						</svg>
					)}
					<span data-i18n={tab.labelKey}>{tab.label}</span>
				</span>
			</a>
		);
	})}
</div>
