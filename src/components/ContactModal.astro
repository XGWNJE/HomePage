---
// ContactModal.astro - Apple-style contact form modal
import { DEFAULT_UI_LANG, getUiText } from '../data/i18n';
import ModalShell from './ModalShell.astro';

const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
const T = getUiText(DEFAULT_UI_LANG);
---

<ModalShell id="contact-modal" titleId="contact-modal-title">
		<div class="mb-6 text-center">
			<h2 id="contact-modal-title" class="text-xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
				<span data-i18n="contact.title">{T['contact.title']}</span>
			</h2>
			<span class="mx-auto mt-2 block h-px w-10 bg-gradient-to-r from-transparent via-[rgb(180,126,36)] to-transparent dark:via-[rgb(226,190,110)]"></span>
		</div>

		<form id="contact-form" class="space-y-3" method="post" data-turnstile-required={TURNSTILE_SITE_KEY ? 'true' : 'false'}>
			<input
				type="text"
				id="contact-name-input"
				name="name"
				placeholder={T['contact.namePlaceholder']}
				data-i18n-placeholder="contact.namePlaceholder"
				autocomplete="name"
				required
				class="field-input"
			/>
			<input
				type="email"
				id="contact-email-input"
				name="email"
				placeholder={T['contact.emailPlaceholder']}
				data-i18n-placeholder="contact.emailPlaceholder"
				autocomplete="email"
				required
				class="field-input"
			/>
			<textarea
				id="contact-message-input"
				name="message"
				placeholder={T['contact.messagePlaceholder']}
				data-i18n-placeholder="contact.messagePlaceholder"
				required
				rows="4"
				class="field-input resize-none leading-6"
			></textarea>
			<p class="text-xs text-zinc-400 dark:text-zinc-500" data-i18n="contact.note">{T['contact.note']}</p>
			{TURNSTILE_SITE_KEY && <div id="contact-turnstile-container" data-sitekey={TURNSTILE_SITE_KEY}></div>}
			<button
				type="submit"
				id="contact-submit"
				class="apple-float-chip flex w-full items-center justify-center gap-2 rounded-xl border border-zinc-200/90 bg-white/80 px-4 py-3 text-base font-medium text-zinc-700 shadow-[0_12px_24px_rgba(15,23,42,0.05)] transition dark:border-zinc-700/90 dark:bg-zinc-900/70 dark:text-zinc-300"
			>
				<span class="apple-float-label">
					<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
					</svg>
					<span data-i18n="contact.send">{T['contact.send']}</span>
				</span>
			</button>
		</form>

		<div id="contact-success" class="hidden text-center">
			<div class="mb-2 flex justify-center">
				<svg class="h-12 w-12 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
					<polyline points="22 4 12 14.01 9 11.01" />
				</svg>
			</div>
			<p class="text-zinc-700 dark:text-zinc-300" data-i18n="contact.success">{T['contact.success']}</p>
		</div>

		<button
			type="button"
			id="contact-modal-close"
			data-modal-close
			class="apple-float-chip mt-4 w-full rounded-xl border border-zinc-200/85 bg-white/72 px-4 py-2.5 text-zinc-600 shadow-[0_10px_20px_rgba(15,23,42,0.04)] transition dark:border-zinc-700/85 dark:bg-zinc-900/62 dark:text-zinc-300"
		>
			<span class="apple-float-label justify-center" data-i18n="actions.cancel">{T['actions.cancel']}</span>
		</button>
</ModalShell>

<script>
	import { sendContactMessage } from '../lib/auth';
	import { getTurnstileToken, removeTurnstile, renderTurnstile, resetTurnstile } from '../lib/turnstile';

	let turnstileWidgetId: string | null = null;
	const i18nText = (key: string, fallback: string) => (window as any).__xgwnjeI18n?.text?.(key) ?? fallback;
	const cleanupTurnstile = () => {
		removeTurnstile(turnstileWidgetId);
		turnstileWidgetId = null;
	};

	const initContactModal = async () => {
		const modal = document.getElementById('contact-modal');
		const modalClose = document.getElementById('contact-modal-close');
		const form = document.getElementById('contact-form') as HTMLFormElement | null;
		const successDiv = document.getElementById('contact-success');
		const nameInput = document.getElementById('contact-name-input') as HTMLInputElement | null;
		const emailInput = document.getElementById('contact-email-input') as HTMLInputElement | null;
		const messageInput = document.getElementById('contact-message-input') as HTMLTextAreaElement | null;
		const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
		const turnstileContainer = document.getElementById('contact-turnstile-container');
		if (!modal || !modalClose || !form || !nameInput || !emailInput || !messageInput || !submitBtn) return;
		if (form.dataset.contactInitialized === 'true') return;
		form.dataset.contactInitialized = 'true';
		const turnstileRequired = form.dataset.turnstileRequired === 'true';
		const ensureTurnstile = async () => {
			if (!turnstileRequired || !turnstileContainer || turnstileWidgetId) return;
			try { turnstileWidgetId = await renderTurnstile(turnstileContainer); } catch { turnstileWidgetId = null; }
		};
		const setSubmitLabel = (label: string) => {
			const labelNode = submitBtn.querySelector<HTMLElement>('[data-i18n="contact.send"]');
			if (labelNode) labelNode.textContent = label;
			else submitBtn.textContent = label;
		};

		void ensureTurnstile();
		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const name = nameInput.value.trim();
			const email = emailInput.value.trim();
			const message = messageInput.value.trim();

			if (!name || !email || !message) {
				alert(i18nText('contact.fillAll', 'Please fill in all fields'));
				return;
			}

			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				alert(i18nText('contact.invalidEmail', 'Please enter a valid email address'));
				return;
			}

			submitBtn.disabled = true;
			setSubmitLabel(i18nText('contact.sending', 'Sending...'));
			await ensureTurnstile();

			const turnstileToken = getTurnstileToken(turnstileWidgetId);

			if (turnstileRequired && !turnstileToken) {
				alert(i18nText('contact.captcha', 'Please complete the captcha verification'));
				submitBtn.disabled = false;
				setSubmitLabel(i18nText('contact.send', 'Send Message'));
				return;
			}

			const result = await sendContactMessage(name, email, message, turnstileToken);
			resetTurnstile(turnstileWidgetId);

			if (result.ok) {
				form.classList.add('hidden');
				successDiv?.classList.remove('hidden');
			} else {
				alert(result.error ?? i18nText('contact.failed', 'Failed to send message'));
				submitBtn.disabled = false;
				setSubmitLabel(i18nText('contact.send', 'Send Message'));
			}
		});

		const openModal = async () => {
			await ensureTurnstile();
			requestAnimationFrame(() => {
				modal.classList.remove('opacity-0', 'invisible');
				modal.classList.add('opacity-100');
				const content = modal.querySelector('.modal-content');
				if (content) {
					content.classList.remove('scale-95', 'opacity-0');
					content.classList.add('scale-100', 'opacity-100');
				}
				modal.setAttribute('aria-hidden', 'false');
			});
		};

		const closeModal = () => {
			modal.classList.add('opacity-0');
			modal.classList.remove('opacity-100');
			const content = modal.querySelector('.modal-content');
			if (content) {
				content.classList.add('scale-95', 'opacity-0');
				content.classList.remove('scale-100', 'opacity-100');
			}
			form.classList.remove('hidden');
			successDiv?.classList.add('hidden');
			submitBtn.disabled = false;
			setSubmitLabel(i18nText('contact.send', 'Send Message'));
			resetTurnstile(turnstileWidgetId);
			setTimeout(() => {
				modal.classList.add('invisible');
			}, 200);
			modal.setAttribute('aria-hidden', 'true');
		};

		modalClose.addEventListener('click', closeModal);

		// Expose open function globally
		(window as any).openContactModal = openModal;
	};

	document.addEventListener('astro:page-load', () => void initContactModal());
	document.addEventListener('astro:before-swap', cleanupTurnstile);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', () => void initContactModal(), { once: true });
	} else {
		void initContactModal();
	}
</script>
