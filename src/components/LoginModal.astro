---
// LoginModal.astro - Solid background login modal with Apple-style animation
import { DEFAULT_UI_LANG, getUiText } from '../data/i18n';
import { API_BASE } from '../lib/config';
import ModalShell from './ModalShell.astro';

const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
const T = getUiText(DEFAULT_UI_LANG);
---
<ModalShell id="login-modal" titleId="login-modal-title" contentClass="w-[360px]">
		<h2 id="login-modal-title" class="mb-6 text-center text-xl font-semibold text-zinc-900 dark:text-zinc-100">
			<span data-i18n="login.title">{T['login.title']}</span>
		</h2>

		<a
			href={`${API_BASE}/api/auth/github/start?returnTo=https%3A%2F%2Fxgwnje.cn%2F`}
			data-github-login
			class="flex w-full items-center justify-center gap-3 rounded-xl bg-zinc-950 px-4 py-3 text-base font-medium text-white no-underline shadow-[0_14px_28px_rgba(24,24,27,0.16)] transition-transform duration-200 ease-[cubic-bezier(0.22,1,0.36,1)] hover:-translate-y-0.5 hover:scale-[1.01] active:translate-y-0 active:scale-[0.99] dark:bg-white dark:text-zinc-900 dark:shadow-[0_14px_30px_rgba(255,255,255,0.08)]"
		>
			<span class="inline-flex items-center gap-3">
				<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
					<path
						d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.523 2 12 2z"
					/>
				</svg>
				<span data-i18n="login.github">{T['login.github']}</span>
			</span>
		</a>

		<div class="my-4 flex items-center gap-3 text-sm">
			<span class="h-px flex-1 bg-zinc-200/85 dark:bg-zinc-700/85"></span>
			<span class="shrink-0 bg-transparent px-0.5 text-[12px] font-medium tracking-[0.08em] text-zinc-400 dark:text-zinc-500" data-i18n="login.or">{T['login.or']}</span>
			<span class="h-px flex-1 bg-zinc-200/85 dark:bg-zinc-700/85"></span>
		</div>

		<form id="email-login-form" class="space-y-3" method="post" data-turnstile-required={TURNSTILE_SITE_KEY ? 'true' : 'false'}>
			<input
				type="email"
				id="email-login-input"
				name="email"
				placeholder={T['login.emailPlaceholder']}
				data-i18n-placeholder="login.emailPlaceholder"
				autocomplete="email"
				required
				class="w-full rounded-lg border border-zinc-200 px-4 py-3 text-zinc-900 placeholder-zinc-400 focus:border-zinc-400 focus:outline-none dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-100 dark:placeholder-zinc-500"
			/>
			{TURNSTILE_SITE_KEY && <div id="login-turnstile-container" data-sitekey={TURNSTILE_SITE_KEY}></div>}
			<button
				type="submit"
				id="email-login-submit"
				class="apple-float-chip flex w-full items-center justify-center gap-2 rounded-xl border border-zinc-200/90 bg-white/80 px-4 py-3 text-base font-medium text-zinc-700 shadow-[0_12px_24px_rgba(15,23,42,0.05)] transition dark:border-zinc-700/90 dark:bg-zinc-900/70 dark:text-zinc-300"
			>
				<span class="apple-float-label">
					<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
						<polyline points="22,6 12,13 2,6" />
					</svg>
					<span data-i18n="login.sendLink">{T['login.sendLink']}</span>
				</span>
			</button>
		</form>

		<div id="email-login-success" class="hidden text-center">
			<div class="mb-2 flex justify-center">
				<svg class="h-12 w-12 text-green-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
					<polyline points="22 4 12 14.01 9 11.01" />
				</svg>
			</div>
			<p class="text-zinc-700 dark:text-zinc-300" data-i18n="login.success">{T['login.success']}</p>
		</div>

		<button
			type="button"
			id="login-modal-close"
			data-modal-close
			class="apple-float-chip mt-4 w-full rounded-xl border border-zinc-200/85 bg-white/72 px-4 py-2.5 text-zinc-600 shadow-[0_10px_20px_rgba(15,23,42,0.04)] transition dark:border-zinc-700/85 dark:bg-zinc-900/62 dark:text-zinc-300"
		>
			<span class="apple-float-label justify-center" data-i18n="actions.cancel">{T['actions.cancel']}</span>
		</button>
</ModalShell>

<script>
	import { sendEmailLogin } from '../lib/auth';
	import { getTurnstileToken, removeTurnstile, renderTurnstile, resetTurnstile } from '../lib/turnstile';

	let turnstileWidgetId: string | null = null;
	const i18nText = (key: string, fallback: string) => (window as any).__xgwnjeI18n?.text?.(key) ?? fallback;
	const cleanupTurnstile = () => {
		removeTurnstile(turnstileWidgetId);
		turnstileWidgetId = null;
	};

	const initLoginForm = async () => {
		const form = document.getElementById('email-login-form') as HTMLFormElement | null;
		const successDiv = document.getElementById('email-login-success');
		const input = document.getElementById('email-login-input') as HTMLInputElement | null;
		const submitBtn = document.getElementById('email-login-submit') as HTMLButtonElement | null;
		const turnstileContainer = document.getElementById('login-turnstile-container');
		if (!form || !input || !submitBtn || form.dataset.loginInitialized === 'true') return;
		form.dataset.loginInitialized = 'true';
		const turnstileRequired = form.dataset.turnstileRequired === 'true';
		const ensureTurnstile = async () => {
			if (!turnstileRequired || !turnstileContainer || turnstileWidgetId) return;
			try { turnstileWidgetId = await renderTurnstile(turnstileContainer); } catch { turnstileWidgetId = null; }
		};
		const setSubmitLabel = (label: string) => {
			const labelNode = submitBtn.querySelector<HTMLElement>('[data-i18n="login.sendLink"]');
			if (labelNode) labelNode.textContent = label;
			else submitBtn.textContent = label;
		};
		void ensureTurnstile();

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			const email = input.value.trim();
			if (!email) return;

			// Basic email validation
			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				alert(i18nText('login.invalidEmail', 'Please enter a valid email address'));
				return;
			}

			// Disable button and show loading
			submitBtn.disabled = true;
			setSubmitLabel(i18nText('login.verifying', 'Verifying...'));
			await ensureTurnstile();

			const turnstileToken = getTurnstileToken(turnstileWidgetId);

			if (turnstileRequired && !turnstileToken) {
				alert(i18nText('login.captcha', 'Please complete the captcha verification'));
				submitBtn.disabled = false;
				setSubmitLabel(i18nText('login.sendLink', 'Send Login Link'));
				return;
			}

			setSubmitLabel(i18nText('login.sending', 'Sending...'));

			const result = await sendEmailLogin(email, turnstileToken);
			resetTurnstile(turnstileWidgetId);

			if (result.ok) {
				form.classList.add('hidden');
				successDiv?.classList.remove('hidden');
			} else {
				alert(result.error ?? i18nText('login.failed', 'Failed to send email'));
				submitBtn.disabled = false;
				setSubmitLabel(i18nText('login.sendLink', 'Send Login Link'));
			}
		});
	};

	document.addEventListener('astro:page-load', () => void initLoginForm());
	document.addEventListener('astro:before-swap', cleanupTurnstile);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', () => void initLoginForm(), { once: true });
	} else {
		void initLoginForm();
	}
</script>
