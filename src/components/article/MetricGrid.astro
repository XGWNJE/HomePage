---
export type MetricItem = {
	label: string;
	value: string;
	detail?: string;
	tone?: 'gold' | 'blue' | 'rose';
};

interface Props {
	title: string;
	eyebrow?: string;
	intro?: string;
	items: MetricItem[];
}

const { title, eyebrow = 'Snapshot', intro, items } = Astro.props;
---

<section class="mdx-metric-block not-prose" aria-label={title}>
	<div class="mdx-section-heading">
		<p class="mdx-section-kicker">{eyebrow}</p>
		<h3>{title}</h3>
		{intro && <p class="mdx-section-intro">{intro}</p>}
	</div>
	<dl class="mdx-metric-grid">
		{
			items.map((item) => (
				<div class:list={['mdx-metric-card', `mdx-metric-card--${item.tone ?? 'gold'}`]}>
					<dt>{item.label}</dt>
					<dd>{item.value}</dd>
					{item.detail && <p>{item.detail}</p>}
				</div>
			))
		}
	</dl>
</section>

<style>
	.mdx-metric-block {
		margin: 2rem 0;
		padding: 1.25rem;
		border: 1px solid rgb(228 228 231);
		border-radius: 1.25rem;
		background: linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(250, 250, 249, 0.82));
		box-shadow: 0 12px 30px rgba(87, 61, 30, 0.07);
	}

	:global(html.dark) .mdx-metric-block {
		border-color: rgb(63 63 70);
		background: linear-gradient(135deg, rgba(24, 24, 27, 0.94), rgba(39, 39, 42, 0.8));
		box-shadow: none;
	}

	.mdx-section-heading {
		max-width: 42rem;
	}

	.mdx-section-kicker {
		margin: 0;
		font-size: 0.68rem;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgb(161 98 7);
	}

	.mdx-section-heading h3 {
		margin: 0.35rem 0 0;
		font-family: ui-serif, Georgia, Cambria, 'Times New Roman', serif;
		font-size: 1.2rem;
		font-weight: 650;
		color: rgb(39 39 42);
	}

	.mdx-section-intro {
		margin: 0.45rem 0 0;
		font-size: 0.875rem;
		line-height: 1.6;
		color: rgb(82 82 91);
	}

	.mdx-metric-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(9rem, 1fr));
		gap: 0.75rem;
		margin: 1rem 0 0;
	}

	.mdx-metric-card {
		position: relative;
		overflow: hidden;
		min-width: 0;
		padding: 0.9rem;
		border: 1px solid rgb(228 228 231);
		border-radius: 0.9rem;
		background: rgba(255, 255, 255, 0.78);
	}

	.mdx-metric-card::before {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 3px;
		content: '';
		background: rgb(180 126 36);
	}

	.mdx-metric-card--blue::before {
		background: rgb(37 99 235);
	}

	.mdx-metric-card--rose::before {
		background: rgb(190 24 93);
	}

	.mdx-metric-card dt {
		font-size: 0.72rem;
		font-weight: 650;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: rgb(113 113 122);
	}

	.mdx-metric-card dd {
		margin: 0.45rem 0 0;
		font-size: 1.55rem;
		font-weight: 700;
		letter-spacing: -0.04em;
		color: rgb(24 24 27);
	}

	.mdx-metric-card p {
		margin: 0.35rem 0 0;
		font-size: 0.78rem;
		line-height: 1.45;
		color: rgb(82 82 91);
	}

	:global(html.dark) .mdx-section-kicker {
		color: rgb(226 190 110);
	}

	:global(html.dark) .mdx-section-heading h3,
	:global(html.dark) .mdx-metric-card dd {
		color: rgb(244 244 245);
	}

	:global(html.dark) .mdx-section-intro,
	:global(html.dark) .mdx-metric-card p {
		color: rgb(161 161 170);
	}

	:global(html.dark) .mdx-metric-card {
		border-color: rgb(63 63 70);
		background: rgba(24, 24, 27, 0.72);
	}

	:global(html.dark) .mdx-metric-card dt {
		color: rgb(161 161 170);
	}
</style>
