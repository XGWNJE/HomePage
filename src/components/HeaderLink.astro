---
import type { HTMLAttributes } from 'astro/types';

/*
 * Nav link primitive used by Header.
 * Encapsulates active-state detection so navigation styling stays consistent everywhere.
 */
type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const pathname = Astro.url.pathname.replace(baseUrl, '/');
const subpath = pathname.match(/[^\/]+/g);
const normalizedHref = typeof href === 'string' ? href.replace(baseUrl, '/').replace(/\/+$/, '/') : href;
const firstSegmentPath = subpath?.[0] ? `/${subpath[0]}/` : '/';
// Segment-level match keeps parent sections highlighted across nested routes.
const isActive = normalizedHref === pathname || normalizedHref === firstSegmentPath;
---

<a
	href={href}
	class:list={[
		className,
		'nav-item apple-float-chip group relative rounded-xl px-3 py-2 font-sans text-zinc-600 no-underline dark:text-zinc-300',
		{ 'nav-item-active bg-zinc-100 text-zinc-900 dark:bg-zinc-800 dark:text-zinc-100': isActive },
	]}
	{...props}
>
	<span class="nav-item-label apple-float-label relative z-[1] inline-block"><slot /></span>
</a>
