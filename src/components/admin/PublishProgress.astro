---
// 发布过场动画：发表/删除文章触发服务器构建时的等待界面。
// 具名组件是项目允许的 SVG 维护位置；动画走 CSS，reduced-motion 下静止。
---

<div
	class="fixed inset-0 z-[80] flex items-center justify-center bg-zinc-950/45 p-4 opacity-0 invisible backdrop-blur-sm transition-opacity duration-200"
	id="publish-progress"
	aria-hidden="true"
	role="dialog"
	aria-modal="true"
	aria-label="发布进度"
>
	<div class="publish-progress-card w-[min(420px,100%)] rounded-3xl border border-zinc-200/80 bg-white p-7 text-center shadow-[0_32px_80px_rgba(15,23,42,0.18)] dark:border-zinc-700 dark:bg-zinc-900">
		<svg class="mx-auto h-28 w-28" viewBox="0 0 112 112" fill="none" aria-hidden="true">
			<!-- 星星 -->
			<g class="pp-star" style="animation-delay:0s"><circle cx="18" cy="26" r="2.2" fill="#f59e0b"/></g>
			<g class="pp-star" style="animation-delay:.6s"><circle cx="94" cy="20" r="1.8" fill="#fbbf24"/></g>
			<g class="pp-star" style="animation-delay:1.1s"><circle cx="100" cy="58" r="2.4" fill="#f59e0b"/></g>
			<g class="pp-star" style="animation-delay:.3s"><circle cx="12" cy="64" r="1.6" fill="#fcd34d"/></g>
			<!-- 轨道虚线 -->
			<ellipse cx="56" cy="60" rx="42" ry="30" stroke="#d4d4d8" stroke-width="1.5" stroke-dasharray="4 6" class="dark:stroke-zinc-600"/>
			<!-- 小火箭 -->
			<g class="pp-rocket">
				<path d="M56 22c8 6 12 15 12 26l6 10c1 1.6-.4 3.4-2.2 2.8l-5.8-2a24 24 0 0 1-20 0l-5.8 2c-1.8.6-3.2-1.2-2.2-2.8l6-10c0-11 4-20 12-26Z" fill="#f59e0b"/>
				<circle cx="56" cy="44" r="6" fill="#fff7ed" stroke="#d97706" stroke-width="2"/>
				<path d="M50 60a7 7 0 0 0 12 0l-6 10-6-10Z" fill="#ea580c"/>
			</g>
			<!-- 尾气泡泡 -->
			<circle class="pp-puff" cx="56" cy="82" r="3" fill="#fdba74" style="animation-delay:0s"/>
			<circle class="pp-puff" cx="50" cy="88" r="2.2" fill="#fed7aa" style="animation-delay:.25s"/>
			<circle class="pp-puff" cx="62" cy="88" r="2.2" fill="#fed7aa" style="animation-delay:.5s"/>
		</svg>

		<p class="m-0 mt-4 text-base font-semibold text-zinc-900 dark:text-zinc-50" data-publish-progress-label>正在准备…</p>
		<p class="m-0 mt-1 text-xs tabular-nums text-zinc-400 dark:text-zinc-500"><span data-publish-elapsed>0</span> 秒</p>

		<ol class="m-0 mt-5 list-none space-y-2.5 p-0 text-left" data-publish-stages>
			<li class="flex items-center gap-2.5 text-sm text-zinc-400 transition-colors dark:text-zinc-500" data-publish-stage="save">
				<span class="pp-dot" aria-hidden="true"></span>保存草稿
			</li>
			<li class="flex items-center gap-2.5 text-sm text-zinc-400 transition-colors dark:text-zinc-500" data-publish-stage="release">
				<span class="pp-dot" aria-hidden="true"></span>服务器构建与切换上线
			</li>
			<li class="flex items-center gap-2.5 text-sm text-zinc-400 transition-colors dark:text-zinc-500" data-publish-stage="done">
				<span class="pp-dot" aria-hidden="true"></span>完成
			</li>
		</ol>

		<p class="m-0 mt-4 hidden rounded-xl border border-rose-200 bg-rose-50/80 px-3.5 py-2.5 text-left text-xs leading-5 text-rose-700 dark:border-rose-900 dark:bg-rose-950/30 dark:text-rose-400" data-publish-progress-error role="alert"></p>
		<button type="button" class="mt-4 hidden rounded-full border border-zinc-200 px-4 py-2 text-sm font-medium text-zinc-600 hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300" data-publish-progress-close>关闭</button>
	</div>
</div>

<style>
	#publish-progress.visible {
		opacity: 1;
		visibility: visible;
	}
	.publish-progress-card {
		transform: translateY(10px) scale(.97);
		transition: transform .22s ease;
	}
	#publish-progress.visible .publish-progress-card {
		transform: translateY(0) scale(1);
	}

	.pp-rocket {
		animation: pp-bob 1.6s ease-in-out infinite;
		transform-origin: 56px 48px;
	}
	.pp-star {
		animation: pp-twinkle 1.8s ease-in-out infinite;
	}
	.pp-puff {
		animation: pp-puff 1.2s ease-out infinite;
	}
	.pp-dot {
		display: inline-block;
		width: .55rem;
		height: .55rem;
		border-radius: 9999px;
		background: currentColor;
		opacity: .45;
	}
	[data-publish-stage].is-active {
		color: rgb(217 119 6);
	}
	[data-publish-stage].is-active .pp-dot {
		opacity: 1;
		animation: pp-pulse 1s ease-in-out infinite;
	}
	[data-publish-stage].is-done {
		color: rgb(5 150 105);
	}
	[data-publish-stage].is-done .pp-dot {
		opacity: 1;
	}

	@keyframes pp-bob {
		0%, 100% { transform: translateY(0) rotate(-2deg); }
		50% { transform: translateY(-6px) rotate(2deg); }
	}
	@keyframes pp-twinkle {
		0%, 100% { opacity: .25; transform: scale(.8); }
		50% { opacity: 1; transform: scale(1.15); }
	}
	@keyframes pp-puff {
		0% { opacity: .9; transform: translateY(0) scale(.7); }
		100% { opacity: 0; transform: translateY(12px) scale(1.3); }
	}
	@keyframes pp-pulse {
		0%, 100% { transform: scale(1); }
		50% { transform: scale(1.5); }
	}

	@media (prefers-reduced-motion: reduce) {
		.pp-rocket, .pp-star, .pp-puff, [data-publish-stage].is-active .pp-dot {
			animation: none;
		}
	}
</style>
