---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comment from '../components/Comment.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import MobileDrawer from '../components/MobileDrawer.astro';
import TocSidebar from '../components/TocSidebar.astro';
import TocDrawer from '../components/TocDrawer.astro';
import { DEFAULT_UI_LANG, getUiText } from '../data/i18n';
import { getPostAnalyticsKey } from '../utils/postAnalytics';
import { getTagSlug } from '../utils/tags';

/* Blog post layout coordinates desktop TOC, mobile drawer TOC, and route-transition-safe scripts. */
type BlogData = CollectionEntry<'blog'>['data'];
type Props = Pick<BlogData, 'title' | 'description' | 'pubDate'> &
	Partial<Omit<BlogData, 'title' | 'description' | 'pubDate' | 'heroImage'>> & {
	heroImage?: ImageMetadata | string;
	profileImage?: string;
	headings?: { depth: number; slug: string; text: string }[];
	rawBody?: string;
	slug?: string;
	analyticsKey?: string;
	metaMode?: 'article' | 'page';
	languageSwitch?: {
		href: string;
		label: string;
	};
	relatedPosts?: CollectionEntry<'blog'>[];
	relatedPostsLang?: 'cn' | 'en';
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	profileImage,
	tags = [],
	headings = [],
	rawBody = '',
	slug,
	analyticsKey = slug,
	metaMode = 'article',
	languageSwitch,
	relatedPosts = [],
	relatedPostsLang = 'en',
} = Astro.props as Props;

const BASE = import.meta.env.BASE_URL;
const T = getUiText(DEFAULT_UI_LANG);
const withBase = (path: string) => {
	// Keep public asset references resilient across root and subpath deployments.
	if (!path) return path;
	if (path.startsWith('http://') || path.startsWith('https://')) return path;
	if (path.startsWith(BASE)) return path;
	return `${BASE}${path.replace(/^\/+/, '')}`;
};

const tocItems = headings.filter((h: { depth: number }) => h.depth === 2 || h.depth === 3 || h.depth === 4);
const articleTags = tags as string[];
const articleRelatedPosts = relatedPosts as CollectionEntry<'blog'>[];
const hasToc = tocItems.length >= 2;
// Reading time is character-based to stay language-neutral for mixed CN/EN content.
const chars = rawBody.replace(/\s+/g, '').length;
const minutes = Math.max(1, Math.ceil(chars / 950));
const charsLabel = chars.toLocaleString('en-US');
---

<html lang={relatedPostsLang === 'cn' ? 'zh-CN' : 'en'}>
	<head>
		<BaseHead title={`${title} | XGWNJE`} description={description} />
	</head>
	<body>
		<!-- Optional decorative background layer (e.g. the About page meteor shower). -->
		<slot name="background" />
		<!-- Scroll-driven reading progress; hidden automatically where unsupported. -->
		<div class="reading-progress" aria-hidden="true"></div>
		<Header showTocButton={hasToc} />
		<MobileDrawer />
		{hasToc && <TocDrawer headings={tocItems} />}

		<!-- Page fade is CSS-driven so route changes remain smooth even when shared-element transitions are bypassed. -->
		<main class="blog-post-page page-fade-in min-h-screen min-w-0 w-full py-10 md:py-14" transition:name="page-main" transition:animate="fade">
			<div class:list={[
				'mx-auto min-w-0 px-4 sm:px-6 lg:px-8',
				metaMode === 'page' ? 'max-w-4xl' : 'max-w-7xl',
			]}>
				<div class:list={[
					'mt-10 min-w-0',
					metaMode === 'page'
						? 'mx-auto max-w-3xl'
						: hasToc
							? 'md:grid md:grid-cols-[240px_minmax(0,1fr)] md:gap-10 lg:grid-cols-[280px_minmax(0,820px)_minmax(0,1fr)] lg:gap-x-10'
							: 'mx-auto max-w-[820px]',
				]}>
					{
						metaMode !== 'page' && hasToc && (
							<aside class="hidden md:block" data-toc-fade-wrap>
								<div class="sticky top-24 self-start">
									<div class="relative">
										<div class="toc-scroll max-h-[calc(100vh-7.5rem)] overflow-auto pr-2" data-toc-scroll="sidebar">
											<TocSidebar headings={tocItems} />
										</div>
										<div
											data-toc-fade="top"
											class="toc-fade toc-fade-top pointer-events-none absolute inset-x-0 top-0 h-8 opacity-0"
										></div>
										<div
											data-toc-fade="bottom"
											class="toc-fade toc-fade-bottom pointer-events-none absolute inset-x-0 bottom-0 h-8 opacity-0"
										></div>
									</div>
								</div>
							</aside>
						)
					}

					<main class:list={[
						'min-w-0',
						metaMode !== 'page' && hasToc && 'lg:col-start-2',
					]}>
						<header class="mb-10 min-w-0 border-b border-zinc-200 pb-6 dark:border-zinc-700">
							{
								metaMode === 'page' ? (
									<div class="mb-1 flex items-center gap-3 text-[11px] font-medium uppercase tracking-[0.14em] text-zinc-400 dark:text-zinc-500">
										<span class="h-px w-10 bg-zinc-200 dark:bg-zinc-700"></span>
										<span class="inline-flex items-center gap-2">
											<span class="inline-flex h-1.5 w-1.5 rounded-full bg-zinc-300 dark:bg-zinc-600"></span>
											<FormattedDate date={pubDate} />
										</span>
									</div>
								) : (
									<p class="m-0 text-sm text-zinc-500 dark:text-zinc-400">
										<FormattedDate date={pubDate} />
										<span class="mx-1.5">&middot;</span>
										<span class="inline-flex items-center gap-1 align-middle" data-post-views-root={analyticsKey ?? ''}>
											<svg viewBox="0 0 24 24" class="h-3.5 w-3.5 opacity-70" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
												<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" stroke-linecap="round" stroke-linejoin="round" />
												<circle cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round" />
											</svg>
											<span data-post-views>...</span>
										</span>
										<span class="mx-1.5">&middot;</span>
										<span>{charsLabel} <span data-i18n="article.chars">{T['article.chars']}</span></span>
										<span class="mx-1.5">&middot;</span>
										<span>{minutes} <span data-i18n="article.min">{T['article.min']}</span></span>
										{updatedDate && (
											<span class="ml-3 inline-block italic">
												<span data-i18n="article.updated">{T['article.updated']}</span> <FormattedDate date={updatedDate} />
											</span>
										)}
									</p>
								)
							}

							<div class="mt-3 flex min-w-0 items-start justify-between gap-4">
								<h1
									class="min-w-0 flex-1 font-sans text-3xl font-semibold leading-tight tracking-tight text-zinc-900 [overflow-wrap:anywhere] dark:text-zinc-100 md:text-4xl"
									transition:animate="fade"
								>
									{title}
								</h1>

								{profileImage && (
									<img
										src={withBase(profileImage)}
										alt={`${title} profile`}
										class="h-14 w-14 shrink-0 rounded-full border border-zinc-200 object-cover dark:border-zinc-700 md:h-16 md:w-16"
										loading="lazy"
									/>
								)}
							</div>

							<p class="mt-3 font-serif text-zinc-600 dark:text-zinc-300">{description}</p>

							{languageSwitch && (
								<div class="mt-4">
									<a
										href={languageSwitch.href}
										class="inline-flex items-center rounded-lg border border-zinc-200 px-3 py-1.5 text-sm font-medium text-zinc-700 no-underline transition-colors hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:text-zinc-100"
										transition:name="lang-switch"
										transition:animate="none"
										data-astro-reload
									>
										{languageSwitch.label}
									</a>
								</div>
							)}

							{articleTags.length > 0 && (
								<div class="mt-4 flex flex-wrap gap-2">
									{articleTags.map((tag) => (
										<a
											href={`${BASE}tags/${encodeURIComponent(getTagSlug(tag))}/`}
										class="inline-flex items-center rounded-md border border-zinc-300/90 bg-zinc-50/96 px-2.5 py-1 text-xs font-medium text-zinc-700 no-underline transition-colors duration-150 ease-out hover:border-zinc-400 hover:bg-white hover:text-zinc-900 dark:border-zinc-700/90 dark:bg-zinc-900/96 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-zinc-100"
										>
											#{tag}
										</a>
									))}
								</div>
							)}
						</header>

						<article class="section-enter min-w-0 w-full max-w-none">
							{
								heroImage &&
									(typeof heroImage === 'string' ? (
										<div class="mb-8 aspect-[16/9] overflow-hidden rounded-2xl border border-zinc-200 bg-white dark:border-zinc-700 dark:bg-zinc-900">
											<img src={withBase(heroImage)} alt={title} class="h-full w-full object-cover" loading="lazy" />
										</div>
									) : (
										<div class="mb-8 overflow-hidden rounded-2xl border border-zinc-200 bg-white dark:border-zinc-700 dark:bg-zinc-900">
											<Image width={1200} height={620} src={heroImage} alt="" class="h-auto w-full" />
										</div>
									))
							}

							<div class="markdown-prose min-w-0">
								<slot />
							</div>
						</article>

						<!-- Related Posts Section -->
						{
							articleRelatedPosts.length > 0 && (
								<section class="mt-12 border-t border-zinc-200 pt-10 dark:border-zinc-700">
									<h2 class="mb-6 font-sans text-2xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100">
										<span data-i18n="article.related">{T['article.related']}</span>
									</h2>
									<div class="grid gap-4 sm:grid-cols-2">
									{articleRelatedPosts.map((relatedPost, relatedIdx) => {
											const postUrl = `${BASE}blog/${relatedPost.id}/`;
											const postTags = ((relatedPost.data.tags ?? []) as string[]).slice(0, 3);
											const relatedAnalyticsKey = getPostAnalyticsKey(relatedPost);
											return (
												<div data-reveal style={`--reveal-delay: ${(relatedIdx % 2) * 80}ms`}>
												<a
													href={postUrl}
													class="card-spotlight group relative block h-full rounded-xl border border-zinc-200 bg-white p-4 transition-all duration-200 hover:border-zinc-300 hover:shadow-lg hover:-translate-y-0.5 dark:border-zinc-700 dark:bg-zinc-800/50 dark:hover:border-zinc-600 dark:hover:bg-zinc-800"
												>
													<h3 class="font-semibold text-zinc-900 transition-colors group-hover:text-orange-600 dark:text-zinc-100 dark:group-hover:text-orange-400">
														{relatedPost.data.title}
													</h3>
													<p class="mt-2 line-clamp-2 text-sm text-zinc-600 dark:text-zinc-400">
														{relatedPost.data.description}
													</p>
													<div class="mt-3 flex items-end justify-between gap-3">
														{postTags.length > 0 ? (
														<div class="flex flex-wrap gap-1.5">
															{postTags.map((tag) => (
																<span class="rounded-md bg-zinc-100 px-2 py-0.5 text-xs font-medium text-zinc-600 dark:bg-zinc-700 dark:text-zinc-300">
																	#{tag}
																</span>
															))}
														</div>
														) : (
														<span></span>
														)}
														<span class="inline-flex shrink-0 items-center gap-1 text-[11px] font-medium text-zinc-400 dark:text-zinc-500" data-related-post-views-root={relatedAnalyticsKey}>
															<svg viewBox="0 0 24 24" class="h-3.5 w-3.5 opacity-70" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
																<path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6Z" stroke-linecap="round" stroke-linejoin="round" />
																<circle cx="12" cy="12" r="3" stroke-linecap="round" stroke-linejoin="round" />
															</svg>
															<span data-related-post-views>...</span>
														</span>
													</div>
												</a>
												</div>
											);
										})}
									</div>
								</section>
							)
						}

						{slug && <Comment postSlug={slug} />}
					</main>

					<div class="hidden lg:block" aria-hidden="true"></div>
				</div>
			</div>
		</main>

		<Footer />

		<button type="button" class="back-to-top" data-back-to-top aria-label={T['actions.backToTop']} data-i18n-aria-label="actions.backToTop">
			<svg class="back-to-top-ring" viewBox="0 0 48 48" aria-hidden="true">
				<circle class="back-to-top-track" cx="24" cy="24" r="21" />
				<circle class="back-to-top-progress" cx="24" cy="24" r="21" data-back-to-top-progress />
			</svg>
			<svg class="back-to-top-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
				<path d="M12 19V5" stroke-linecap="round" />
				<path d="m5 12 7-7 7 7" stroke-linecap="round" stroke-linejoin="round" />
			</svg>
		</button>

		<div
			id="img-lightbox"
			class="fixed inset-0 z-[999] hidden items-center justify-center overflow-auto bg-black/65 p-4 backdrop-blur-md md:p-8 dark:bg-black/75"
			aria-hidden="true"
		>
			<button
				id="img-lightbox-close"
				type="button"
				class="fixed right-4 top-4 inline-flex h-10 w-10 items-center justify-center rounded-full border border-white/25 bg-black/35 text-white transition-colors hover:bg-black/55"
				aria-label={T['actions.closeImage']}
				data-i18n-aria-label="actions.closeImage"
				data-lightbox-close
			>
				<svg viewBox="0 0 24 24" class="h-5 w-5 fill-current" aria-hidden="true">
					<path d="M6.7 5.3a1 1 0 0 0-1.4 1.4L10.6 12l-5.3 5.3a1 1 0 1 0 1.4 1.4l5.3-5.3 5.3 5.3a1 1 0 1 0 1.4-1.4L13.4 12l5.3-5.3a1 1 0 0 0-1.4-1.4L12 10.6 6.7 5.3Z" />
				</svg>
			</button>
			<figure class="m-0 flex max-w-full flex-col items-center gap-3">
				<img
					id="img-lightbox-target"
					alt=""
					class="mx-auto block h-auto max-h-[88dvh] max-w-[92vw] rounded-xl object-contain shadow-2xl"
				/>
				<figcaption
					id="img-lightbox-caption"
					class="max-w-[78vw] text-center font-sans text-[13px] leading-6 text-zinc-300 empty:hidden"
				></figcaption>
			</figure>
		</div>

		<style is:global>
			.markdown-prose :is(h2, h3, h4) {
				scroll-margin-top: 7rem;
			}
		</style>

		<script>
			import { mountBlogPostRuntime } from '../client/blog-post/runtime';

			mountBlogPostRuntime();
		</script>
	</body>
</html>
