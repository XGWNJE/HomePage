---
import LinkCard from '../../components/LinkCard.astro';
import MeteorShower from '../../components/MeteorShower.astro';
import PageHeading from '../../components/PageHeading.astro';
import { SITE_TITLE } from '../../consts';
import { links, type LinkGroup } from '../../data/links';
import { DEFAULT_UI_LANG, getUiText } from '../../data/i18n';
import SiteLayout from '../../layouts/SiteLayout.astro';

type LinkTextKey = Extract<keyof ReturnType<typeof getUiText>, `links.${string}`>;
type LinkGroupDefinition = {
	id: LinkGroup;
	titleKey: LinkTextKey;
	subtitleKey: LinkTextKey;
};

const base = import.meta.env.BASE_URL || '/';
const T = getUiText(DEFAULT_UI_LANG);
const linkGroupDefinitions: LinkGroupDefinition[] = [
	{
		id: 'profiles',
		titleKey: 'links.profiles',
		subtitleKey: 'links.profilesSubtitle',
	},
	{
		id: 'web-effects',
		titleKey: 'links.webEffects',
		subtitleKey: 'links.webEffectsSubtitle',
	},
	{
		id: 'inspiration',
		titleKey: 'links.inspiration',
		subtitleKey: 'links.inspirationSubtitle',
	},
	{
		id: 'cross-platform',
		titleKey: 'links.crossPlatform',
		subtitleKey: 'links.crossPlatformSubtitle',
	},
];
const linkGroups = linkGroupDefinitions
	.map((definition) => ({ ...definition, items: links.filter((item) => item.group === definition.id) }))
	.filter((group) => group.items.length > 0);
---

<SiteLayout title={`Links & Inspiration | ${SITE_TITLE}`} description="Personal profiles and a curated reference library for web, cross-platform, and native visual effects.">
	<Fragment slot="background">
		<MeteorShower density={0.5} heightVh={42} />
	</Fragment>
	<main class="links-page mx-auto max-w-6xl px-4 py-12" transition:name="page-main" transition:animate="fade">
		<PageHeading
			eyebrow={T['links.eyebrow']}
			eyebrowKey="links.eyebrow"
			title={T['links.title']}
			titleKey="links.title"
			accent={T['links.accent']}
			accentKey="links.accent"
			subtitle={T['links.subtitle']}
			subtitleKey="links.subtitle"
		/>

		{
			linkGroups.map((group, groupIndex) => (
				<section class:list={['section-enter', groupIndex > 0 ? 'mt-14' : 'mt-8']}>
					<div class="mb-4">
						<h2 class="flex items-center gap-2.5 text-sm font-semibold uppercase tracking-[0.18em] text-zinc-500 dark:text-zinc-400">
							<span class="h-px w-6 bg-gradient-to-r from-[rgb(180,126,36)] to-transparent dark:from-[rgb(226,190,110)]"></span>
							<span data-i18n={group.titleKey}>{T[group.titleKey]}</span>
						</h2>
						<p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400" data-i18n={group.subtitleKey}>{T[group.subtitleKey]}</p>
					</div>
					<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
						{
							group.items.map((item, itemIndex) => (
								<LinkCard item={item} base={base} visitLabel={T['actions.visit']} delay={(itemIndex % 3) * 70} />
							))
						}
					</div>
				</section>
			))
		}
	</main>
	<style>
		:global(.links-page [data-i18n='links.subtitle']),
		:global(.links-page [data-link-card-title]),
		:global(.links-page [data-link-card-description]) {
			overflow-wrap: anywhere;
			word-break: break-word;
		}

		:global(.links-page [data-link-card]) {
			min-width: 0;
		}
	</style>
</SiteLayout>
