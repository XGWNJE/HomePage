---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import MobileDrawer from '../../components/MobileDrawer.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_TITLE } from '../../consts';
import { DEFAULT_UI_LANG, getUiText } from '../../data/i18n';
import { getPostLang } from '../../utils/postAnalytics';
import { getPublishedPosts } from '../../utils/publishedPosts';
import { getTagSlug, normalizeTagLabel } from '../../utils/tags';

export async function getStaticPaths() {
	const posts = await getPublishedPosts();
	const allTags = new Map<string, string>();
	for (const post of posts) {
		for (const tag of post.data.tags ?? []) {
			const label = normalizeTagLabel(tag);
			if (!label) continue;
			const slug = getTagSlug(label);
			if (!allTags.has(slug)) allTags.set(slug, label);
		}
	}

	return [...allTags.entries()].map(([slug, label]) => ({
		params: { tag: slug },
		props: { displayTag: label },
	}));
}

const BASE = import.meta.env.BASE_URL;
const T = getUiText(DEFAULT_UI_LANG);
const currentTagSlug = decodeURIComponent(Astro.params.tag ?? '');
const displayTag = Astro.props.displayTag ?? currentTagSlug;
const tagDescription = `Explore all articles tagged with "${displayTag}". Find tutorials, guides, and technical notes related to ${displayTag} on this blog.`;
const posts = (await getPublishedPosts())
	.filter((post) => (post.data.tags ?? []).some((tag: string) => getTagSlug(tag) === currentTagSlug))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const postGroupCount = new Set(posts.map((post) => post.data.group ?? post.id.replace(/-(cn|en)$/, ''))).size;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`Tag: ${displayTag} | ${SITE_TITLE} - Articles & Tutorials`} description={tagDescription} />
	</head>
	<body>
		<Header />
		<MobileDrawer />
		<main class="page-shell page-fade-in py-10 md:py-14" transition:name="page-main" transition:animate="fade">
			<section class="section-enter mx-auto max-w-4xl">
				<h1 class="text-3xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-100 md:text-4xl" transition:name="page-title" transition:animate="fade">
					<span data-i18n="tags.tagPrefix">{T['tags.tagPrefix']}</span> {displayTag}
				</h1>
				<p class="mt-2 font-sans text-zinc-500 dark:text-zinc-400">
					{postGroupCount} <span data-i18n={postGroupCount === 1 ? 'tags.postSingular' : 'tags.postPlural'}>{postGroupCount === 1 ? T['tags.postSingular'] : T['tags.postPlural']}</span>
				</p>
				<ul class="mt-8 grid gap-4">
					{
						posts.map((post, idx) => (
							<li class="relative" data-reveal data-i18n-content-lang={getPostLang(post)} style={`--reveal-delay: ${Math.min(idx * 60, 180)}ms`}>
								<PostCard post={post} base={BASE} maxMobile={3} maxDesktop={null} reloadOnNavigate={true} />
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
