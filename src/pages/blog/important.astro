---
// This page redirects to /blog/important/ for Important view
import BlogViewTabs from '../../components/BlogViewTabs.astro';
import MeteorShower from '../../components/MeteorShower.astro';
import PageHeading from '../../components/PageHeading.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_TITLE } from '../../consts';
import { DEFAULT_UI_LANG, getUiText } from '../../data/i18n';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getPostLang } from '../../utils/postAnalytics';
import { getPublishedPosts } from '../../utils/publishedPosts';

const BASE = import.meta.env.BASE_URL;
const T = getUiText(DEFAULT_UI_LANG);

// Get all posts
const allPosts = await getPublishedPosts();

// Filter important posts (where important === true), sorted by importantOrder
const importantPosts = allPosts
	.filter((post) => post.data.important === true)
	.sort((a, b) => (b.data.importantOrder || 0) - (a.data.importantOrder || 0));

---

<SiteLayout title={`Important Articles | ${SITE_TITLE} - Curated Technical Guides`} description="A curated selection of the most valuable articles on this blog. Find essential tutorials, guides, and technical notes worth reading.">
	<Fragment slot="background">
		<MeteorShower density={0.4} heightVh={40} />
	</Fragment>
		<main class="page-shell page-fade-in py-10 md:py-14" transition:name="page-main" transition:animate="fade">
			<section class="mx-auto max-w-4xl">
				<PageHeading
					eyebrow={T['blog.eyebrow']}
					eyebrowKey="blog.eyebrow"
					title={T['blog.title']}
					titleKey="blog.title"
					subtitle={T['blog.importantSubtitle']}
					subtitleKey="blog.importantSubtitle"
				>
					<BlogViewTabs slot="actions" current="important" />
				</PageHeading>

				<div class="mt-8 min-h-[24rem]">
					<div role="tabpanel">
						{importantPosts.length > 0 ? (
							<ul class="grid gap-4">
								{importantPosts.map((post, idx) => (
									<li class="relative" data-reveal data-i18n-content-lang={getPostLang(post)} style={`--reveal-delay: ${Math.min(idx * 60, 180)}ms`}>
										<PostCard post={post} base={BASE} maxMobile={3} maxDesktop={null} reloadOnNavigate={true} />
									</li>
								))}
							</ul>
						) : (
							<div class="flex h-32 flex-col items-center justify-center text-zinc-500 dark:text-zinc-400">
								<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mb-2 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
									<path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
								</svg>
								<p data-i18n="blog.noImportant">{T['blog.noImportant']}</p>
							</div>
						)}
					</div>
				</div>
			</section>
		</main>

		<style is:global>
			@media (prefers-reduced-motion: reduce) {
				.card-enter {
					transition: none !important;
					animation: none !important;
					transform: none !important;
					opacity: 1 !important;
				}
			}
		</style>
</SiteLayout>
