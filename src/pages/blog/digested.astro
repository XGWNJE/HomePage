---
import BlogViewTabs from '../../components/BlogViewTabs.astro';
import MeteorShower from '../../components/MeteorShower.astro';
import PageHeading from '../../components/PageHeading.astro';
import PostCard from '../../components/PostCard.astro';
import { SITE_TITLE } from '../../consts';
import { DEFAULT_UI_LANG, getUiText } from '../../data/i18n';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getPostLang } from '../../utils/postAnalytics';
import { getPublishedPosts } from '../../utils/publishedPosts';

const BASE = import.meta.env.BASE_URL;
const T = getUiText(DEFAULT_UI_LANG);
const digestedPosts = (await getPublishedPosts())
	.filter((post) => post.data.category === '消化')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<SiteLayout title={`消化 | ${SITE_TITLE}`} description={T['blog.digestedSubtitle']}>
	<Fragment slot="background">
		<MeteorShower density={0.4} heightVh={40} />
	</Fragment>
	<main class="page-shell page-fade-in py-10 md:py-14" transition:name="page-main" transition:animate="fade">
		<section class="mx-auto max-w-4xl">
			<PageHeading
				eyebrow={T['blog.eyebrow']}
				eyebrowKey="blog.eyebrow"
				title={T['blog.title']}
				titleKey="blog.title"
				subtitle={T['blog.digestedSubtitle']}
				subtitleKey="blog.digestedSubtitle"
			>
				<div class="mt-6 overflow-x-auto pb-1">
					<BlogViewTabs current="digested" />
				</div>
			</PageHeading>

			<div class="mt-8 min-h-[24rem]" role="tabpanel">
				{digestedPosts.length > 0 ? (
					<ul class="grid gap-4">
						{digestedPosts.map((post, idx) => (
							<li class="relative" data-reveal data-i18n-content-lang={getPostLang(post)} style={`--reveal-delay: ${Math.min(idx * 60, 180)}ms`}>
								<PostCard post={post} base={BASE} maxMobile={3} maxDesktop={null} reloadOnNavigate={true} />
							</li>
						))}
					</ul>
				) : (
					<div class="flex h-32 items-center justify-center text-zinc-500 dark:text-zinc-400">
						<p data-i18n="blog.noDigested">{T['blog.noDigested']}</p>
					</div>
				)}
			</div>
		</section>
	</main>
</SiteLayout>
