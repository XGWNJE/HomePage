---
import type { GetStaticPaths } from 'astro';
import BlogViewTabs from '../../../components/BlogViewTabs.astro';
import MeteorShower from '../../../components/MeteorShower.astro';
import PageHeading from '../../../components/PageHeading.astro';
import Pagination from '../../../components/Pagination.astro';
import PostCard from '../../../components/PostCard.astro';
import { SITE_TITLE } from '../../../consts';
import { DEFAULT_UI_LANG, getUiText } from '../../../data/i18n';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { getPostLang } from '../../../utils/postAnalytics';
import { getPublishedPosts } from '../../../utils/publishedPosts';

const BASE_DESCRIPTION = 'Browse all articles on this blog. Find technical tutorials, engineering guides, research notes, and programming tips.';

const BASE = import.meta.env.BASE_URL;
const T = getUiText(DEFAULT_UI_LANG);

export const getStaticPaths = (async ({ paginate }) => {
	// Keep page size colocated with route generation so pagination stays deterministic at build time.
	const PAGE_SIZE = 6;
	const posts = (await getPublishedPosts()).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

	// Page 1 is intentionally handled by /blog/ to avoid duplicate first-page routes.
	return paginate(posts, { pageSize: PAGE_SIZE }).filter(
		(entry) => entry.props.page.currentPage > 1,
	);
}) satisfies GetStaticPaths;

interface Props {
	page: {
		currentPage: number;
		lastPage: number;
		data: any[];
	};
}

const { page } = Astro.props as Props;

// Generate unique description for each page to avoid SEO penalties
const pageDescription = page.currentPage === 1
	? BASE_DESCRIPTION
	: `Browse page ${page.currentPage} of ${page.lastPage}. ${BASE_DESCRIPTION}`;

---

<SiteLayout title={`Blog Page ${page.currentPage} | ${SITE_TITLE} - All Articles`} description={pageDescription}>
	<Fragment slot="head">
		<meta name="robots" content="noindex,follow" />
	</Fragment>
	<Fragment slot="background">
		<MeteorShower density={0.4} heightVh={40} />
	</Fragment>
		<main class="page-shell page-fade-in py-10 md:py-14" transition:name="page-main" transition:animate="fade">
			<section class="mx-auto max-w-4xl">
				<PageHeading
					eyebrow={T['blog.eyebrow']}
					eyebrowKey="blog.eyebrow"
					title={T['blog.title']}
					titleKey="blog.title"
					subtitle={T['blog.subtitle']}
					subtitleKey="blog.subtitle"
				>
					<div class="mt-6 overflow-x-auto pb-1">
						<BlogViewTabs current="latest" />
					</div>
				</PageHeading>

				<ul class="mt-8 grid gap-4">
					{
						page.data.map((post, idx) => (
								<li class="relative" data-reveal data-i18n-content-lang={getPostLang(post)} style={`--reveal-delay: ${Math.min(idx * 60, 180)}ms`}>
								<PostCard post={post} base={BASE} maxMobile={3} maxDesktop={null} reloadOnNavigate={true} />
							</li>
						))
					}
				</ul>
				<div>
					<Pagination currentPage={page.currentPage} lastPage={page.lastPage} basePath={`${BASE}blog`} />
				</div>
			</section>
		</main>
</SiteLayout>
