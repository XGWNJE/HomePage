---
import SiteLayout from '../../layouts/SiteLayout.astro';
import ModalShell from '../../components/ModalShell.astro';
import AdminSubscriptionCard from '../../components/admin/AdminSubscriptionCard.astro';
import PublishProgress from '../../components/admin/PublishProgress.astro';
---

<SiteLayout title="管理台 | XGWNJE" description="XGWNJE 站点内容与消息管理台。">
	<Fragment slot="head">
		<meta name="robots" content="noindex, nofollow" />
	</Fragment>
		<main class="page-shell page-fade-in py-6 md:py-8" data-admin-root transition:name="page-main" transition:animate="fade">
			<section class="mx-auto max-w-6xl">
				<header class="flex items-center justify-between gap-4 border-b border-zinc-200/80 pb-3 dark:border-zinc-800/80">
					<h1 class="m-0 text-base font-semibold text-zinc-950 dark:text-zinc-50">站点管理台</h1>
					<div class="flex items-center gap-4">
						<span class="text-[11px] text-zinc-400 dark:text-zinc-500" data-admin-auth-message>正在验证当前会话…</span>
						<a href="/" class="text-xs font-medium text-amber-700 no-underline hover:underline dark:text-amber-400">返回站点 →</a>
					</div>
				</header>

				<section class="mt-4 hidden rounded-xl border border-rose-200 bg-rose-50/80 p-4 dark:border-rose-900 dark:bg-rose-950/30" data-admin-auth-state aria-live="polite">
					<p class="m-0 text-sm font-medium text-rose-700 dark:text-rose-400" data-admin-auth-error></p>
				</section>

				<div class="hidden" data-admin-workspace>
					<nav class="flex items-center gap-5 overflow-x-auto border-b border-zinc-200/80 py-2.5 dark:border-zinc-800/80" aria-label="管理台分区" data-admin-nav>
						<button type="button" class="admin-tab" data-admin-tab="articles" aria-pressed="true">文章 <span data-admin-tab-count="articles"></span></button>
						<button type="button" class="admin-tab" data-admin-tab="comments" aria-pressed="false">评论 <span data-admin-tab-count="comments"></span></button>
						<button type="button" class="admin-tab" data-admin-tab="messages" aria-pressed="false">消息 <span data-admin-tab-count="messages"></span></button>
						<button type="button" class="admin-tab" data-admin-tab="subscriptions" aria-pressed="false">订阅</button>
					</nav>

					<div class="pt-2" data-admin-panel="articles">
						<section aria-labelledby="admin-articles-heading">
							<h2 id="admin-articles-heading" class="sr-only">文章管理</h2>
							<div class="flex items-center justify-between gap-4 py-2">
								<div class="flex items-center gap-3.5" role="group" aria-label="文章筛选">
									<button type="button" class="admin-mini-filter" data-admin-article-filter="all" aria-pressed="true">全部 <span data-admin-filter-count="all"></span></button>
									<button type="button" class="admin-mini-filter" data-admin-article-filter="draft" aria-pressed="false">草稿 <span data-admin-filter-count="draft"></span></button>
									<button type="button" class="admin-mini-filter" data-admin-article-filter="published" aria-pressed="false">已发布 <span data-admin-filter-count="published"></span></button>
								</div>
								<div class="flex items-center gap-3.5">
									<button type="button" class="text-[11px] text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100" data-admin-articles-refresh>刷新</button>
									<a href="/admin/editor/" class="rounded-md bg-amber-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-amber-700" data-admin-article-new>＋ 新建文章</a>
								</div>
							</div>
							<div class="hidden border-b border-zinc-200/80 pb-1.5 text-[10px] font-semibold uppercase tracking-[0.1em] text-zinc-400 dark:border-zinc-800/80 dark:text-zinc-500 sm:grid sm:grid-cols-[minmax(0,1fr)_90px_110px_100px_130px]" aria-hidden="true">
								<span>标题</span><span>语言</span><span>分类</span><span>日期</span><span>操作</span>
							</div>
							<div class="divide-y divide-zinc-200/70 border-b border-zinc-200/80 dark:divide-zinc-800/70 dark:border-zinc-800/80" data-admin-articles aria-live="polite"></div>
							<p class="m-0 pt-2.5 text-[11px] text-zinc-400 dark:text-zinc-500" data-admin-articles-status aria-live="polite"></p>
						</section>
					</div>

					<div class="hidden" data-admin-panel="comments">
						<section aria-labelledby="admin-comments-heading">
							<h2 id="admin-comments-heading" class="sr-only">评论审阅</h2>
							<div class="flex flex-wrap items-center justify-between gap-3 py-2">
								<div class="flex items-center gap-3.5" role="group" aria-label="评论状态筛选">
									<button type="button" class="admin-mini-filter" data-admin-comment-filter="all" aria-pressed="true">全部</button>
									<button type="button" class="admin-mini-filter" data-admin-comment-filter="pending" aria-pressed="false">待审</button>
									<button type="button" class="admin-mini-filter" data-admin-comment-filter="approved" aria-pressed="false">已批准</button>
									<button type="button" class="admin-mini-filter" data-admin-comment-filter="rejected" aria-pressed="false">已拒绝</button>
								</div>
								<div class="flex items-center gap-3.5">
									<span class="text-[11px] text-zinc-400 dark:text-zinc-500" data-admin-stats>全部 <span data-admin-stat="total">—</span> · 待审 <span data-admin-stat="pending">—</span> · 已批准 <span data-admin-stat="approved">—</span> · 已拒绝 <span data-admin-stat="rejected">—</span></span>
									<button type="button" class="text-[11px] text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100" data-admin-refresh>刷新</button>
								</div>
							</div>
							<div class="divide-y divide-zinc-200/70 border-y border-zinc-200/80 dark:divide-zinc-800/70 dark:border-zinc-800/80" data-admin-comments aria-live="polite"></div>
						</section>
					</div>

					<div class="hidden" data-admin-panel="messages">
						<div class="grid gap-8 lg:grid-cols-2">
							<section aria-labelledby="admin-contact-heading">
								<div class="border-b border-zinc-200/80 pb-2 dark:border-zinc-800/80"><h2 id="admin-contact-heading" class="m-0 text-sm font-semibold text-zinc-900 dark:text-zinc-100">联系消息</h2></div>
								<div class="divide-y divide-zinc-200/70 dark:divide-zinc-800/70" data-admin-contact-messages></div>
							</section>
							<section aria-labelledby="admin-outbox-heading">
								<div class="border-b border-zinc-200/80 pb-2 dark:border-zinc-800/80"><h2 id="admin-outbox-heading" class="m-0 text-sm font-semibold text-zinc-900 dark:text-zinc-100">邮件队列</h2></div>
								<div class="divide-y divide-zinc-200/70 dark:divide-zinc-800/70" data-admin-outbox></div>
							</section>
						</div>
					</div>

					<div class="hidden" data-admin-panel="subscriptions">
						<AdminSubscriptionCard />
					</div>
				</div>
			</section>
		</main>

		<style>
			.admin-tab { position: relative; padding: 0 0 2px; font-size: .75rem; font-weight: 500; color: rgb(161 161 170); transition: color .15s ease; white-space: nowrap; }
			.admin-tab:hover { color: rgb(82 82 91); }
			.admin-tab[aria-pressed='true'] { color: rgb(180 83 9); font-weight: 600; }
			.admin-tab[aria-pressed='true']::after { content: ''; position: absolute; left: 0; right: 0; bottom: -11px; height: 2px; background: rgb(217 119 6); }
			:global(.dark) .admin-tab:hover { color: rgb(212 212 216); }
			:global(.dark) .admin-tab[aria-pressed='true'] { color: rgb(251 191 36); }
			.admin-mini-filter { font-size: 11px; color: rgb(161 161 170); transition: color .15s ease; }
			.admin-mini-filter:hover { color: rgb(82 82 91); }
			.admin-mini-filter[aria-pressed='true'] { color: rgb(24 24 27); font-weight: 600; }
			:global(.dark) .admin-mini-filter:hover { color: rgb(212 212 216); }
			:global(.dark) .admin-mini-filter[aria-pressed='true'] { color: rgb(244 244 245); }
		</style>

		<ModalShell id="admin-article-view-modal" titleId="admin-article-view-title" contentClass="w-[min(720px,100%)]">
			<div class="flex items-start justify-between gap-4">
				<div>
					<h3 id="admin-article-view-title" class="m-0 text-lg font-semibold text-zinc-950 dark:text-zinc-50" data-admin-article-view-title>文章详情</h3>
					<p class="mt-1 font-mono text-[11px] text-zinc-400 dark:text-zinc-500" data-admin-article-view-meta></p>
				</div>
				<button type="button" data-modal-close class="rounded-full border border-zinc-200 px-3 py-1.5 text-xs font-medium text-zinc-500 hover:border-zinc-300 hover:text-zinc-800 dark:border-zinc-700 dark:text-zinc-300">关闭</button>
			</div>
			<pre class="mt-4 max-h-[60dvh] overflow-auto whitespace-pre-wrap break-words rounded-xl bg-zinc-50 p-4 font-mono text-xs leading-5 text-zinc-700 dark:bg-zinc-800/60 dark:text-zinc-300" data-admin-article-view-source></pre>
		</ModalShell>

		<ModalShell id="admin-article-delete-modal" titleId="admin-article-delete-title" contentClass="w-[min(520px,100%)]">
			<h3 id="admin-article-delete-title" class="m-0 text-lg font-semibold text-zinc-950 dark:text-zinc-50">删除这篇文章？</h3>
			<p class="mt-3 text-sm leading-6 text-zinc-600 dark:text-zinc-400" data-admin-article-delete-body></p>
			<div class="mt-3 rounded-lg bg-rose-50 px-3 py-2 text-xs leading-5 text-rose-700 dark:bg-rose-950/30 dark:text-rose-300">仅删除一种语言会破坏中英配对检查；如果另一语言版本存在，建议勾选一并删除。删除会触发一次完整重新发布（约 25 秒），线上立即下架，可通过 git 历史找回。</div>
			<label class="mt-4 flex items-center gap-2 text-sm text-zinc-600 dark:text-zinc-300">
				<input type="checkbox" data-admin-article-delete-pair class="h-4 w-4 accent-rose-700" />
				同时删除对应语言版本（-cn / -en）
			</label>
			<div class="mt-5 flex justify-end gap-2">
				<button type="button" data-modal-close class="rounded-full border border-zinc-200 px-4 py-2 text-sm font-medium text-zinc-600 hover:border-zinc-300 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300">取消</button>
				<button type="button" data-admin-article-delete-confirm class="rounded-full bg-rose-700 px-4 py-2 text-sm font-semibold text-white hover:bg-rose-800 disabled:opacity-60">确认删除</button>
			</div>
		</ModalShell>

		<PublishProgress />
</SiteLayout>

<script>
	import {
		approveComment,
		checkAdmin,
		deleteAdminArticle,
		deleteComment,
		getAdminArticle,
		getAdminArticleDrafts,
		deleteAdminArticleDraft,
		getAdminArticles,
		getAdminComments,
		getAdminContactMessages,
		getAdminOutbox,
		getAdminStats,
		getSubscriptionStatus,
		rejectComment,
		type AdminArticle,
		type AdminArticleDraftSummary,
		type AdminComment,
		type AdminContactMessage,
		type AdminOutboxItem,
	} from '../../lib/admin';
	import { createPublishProgress } from '../../lib/publishProgress';

	type CommentFilter = AdminComment['status'] | 'all';
	const initAdminPage = () => {
	const root = document.querySelector<HTMLElement>('[data-admin-root]');
	if (!root || root.dataset.adminInitialized === 'true') return;
	root.dataset.adminInitialized = 'true';
	const authState = root?.querySelector<HTMLElement>('[data-admin-auth-state]');
	const authMessage = root?.querySelector<HTMLElement>('[data-admin-auth-message]');
	const workspace = root?.querySelector<HTMLElement>('[data-admin-workspace]');
	const subscriptionTab = root?.querySelector<HTMLButtonElement>('[data-admin-tab="subscriptions"]');
	const commentsRoot = root?.querySelector<HTMLElement>('[data-admin-comments]');
	const contactsRoot = root?.querySelector<HTMLElement>('[data-admin-contact-messages]');
	const outboxRoot = root?.querySelector<HTMLElement>('[data-admin-outbox]');
	let currentFilter: CommentFilter = 'all';

	const createElement = <K extends keyof HTMLElementTagNameMap>(tag: K, className = '', text = '') => {
		const node = document.createElement(tag);
		if (className) node.className = className;
		if (text) node.textContent = text;
		return node;
	};

	const formatDate = (timestamp: number) => new Date(timestamp).toLocaleString('zh-CN', {
		year: 'numeric', month: '2-digit', day: '2-digit', hour: '2-digit', minute: '2-digit',
	});

	const emptyState = (message: string) => createElement('p', 'rounded-2xl border border-dashed border-zinc-300 px-5 py-8 text-center text-sm text-zinc-500 dark:border-zinc-700 dark:text-zinc-400', message);

	const actionButton = (label: string, action: string, id: string, tone: 'default' | 'danger' = 'default') => {
		const button = createElement('button', tone === 'danger'
			? 'text-[11px] text-rose-600 hover:text-rose-800 dark:text-rose-400 dark:hover:text-rose-300'
			: 'text-[11px] text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100', label);
		button.type = 'button';
		button.setAttribute('data-admin-action', action);
		button.dataset.commentId = id;
		return button;
	};

	const COMMENT_STATUS_TONE: Record<string, string> = {
		pending: 'text-amber-700 dark:text-amber-400',
		approved: 'text-emerald-600 dark:text-emerald-400',
		rejected: 'text-rose-600 dark:text-rose-400',
	};

	const renderComments = (comments: AdminComment[]) => {
		if (!commentsRoot) return;
		commentsRoot.replaceChildren();
		if (!comments.length) return commentsRoot.append(emptyState('当前筛选条件下没有评论。'));
		for (const comment of comments) {
			const row = createElement('article', 'py-3');
			const header = createElement('div', 'flex flex-wrap items-baseline gap-x-2.5 gap-y-1');
			header.append(createElement('span', 'text-xs font-semibold text-zinc-900 dark:text-zinc-100', comment.name || comment.login));
			header.append(createElement('span', 'text-[11px] text-zinc-400 dark:text-zinc-500', `@${comment.login} · ${formatDate(comment.created_at)}`));
			header.append(createElement('span', `text-[10px] font-semibold uppercase tracking-[0.08em] ${COMMENT_STATUS_TONE[comment.status] ?? 'text-zinc-400 dark:text-zinc-500'}`, comment.status));
			row.append(header);
			row.append(createElement('p', 'm-0 mt-1.5 whitespace-pre-wrap break-words text-sm leading-6 text-zinc-700 dark:text-zinc-300', comment.body));
			const footer = createElement('div', 'mt-1.5 flex flex-wrap items-center gap-x-2.5 gap-y-1');
			footer.append(createElement('span', 'break-all font-mono text-[11px] text-zinc-400 dark:text-zinc-500', comment.post_slug));
			const actions = createElement('span', 'ml-auto flex items-center gap-2.5');
			if (comment.status !== 'approved') actions.append(actionButton('批准', 'approve', comment.id));
			if (comment.status !== 'rejected') actions.append(actionButton('拒绝', 'reject', comment.id));
			actions.append(actionButton('删除', 'delete', comment.id, 'danger'));
			footer.append(actions);
			row.append(footer);
			commentsRoot.append(row);
		}
	};

	const renderContacts = (messages: AdminContactMessage[]) => {
		if (!contactsRoot) return;
		contactsRoot.replaceChildren();
		if (!messages.length) return contactsRoot.append(emptyState('暂无联系消息。'));
		for (const message of messages) {
			const row = createElement('article', 'py-3');
			row.append(createElement('p', 'm-0 text-xs font-semibold text-zinc-900 dark:text-zinc-100', message.name));
			row.append(createElement('p', 'm-0 mt-0.5 break-all text-[11px] text-zinc-400 dark:text-zinc-500', `${message.email} · ${formatDate(message.created_at)}`));
			row.append(createElement('p', 'm-0 mt-1.5 whitespace-pre-wrap break-words text-sm leading-6 text-zinc-700 dark:text-zinc-300', message.message));
			contactsRoot.append(row);
		}
	};

	const renderOutbox = (items: AdminOutboxItem[]) => {
		if (!outboxRoot) return;
		outboxRoot.replaceChildren();
		if (!items.length) return outboxRoot.append(emptyState('邮件队列为空。'));
		for (const item of items) {
			const row = createElement('article', 'py-3');
			row.append(createElement('p', 'm-0 text-xs font-semibold text-zinc-900 dark:text-zinc-100', item.subject || item.type));
			row.append(createElement('p', 'm-0 mt-0.5 break-all text-[11px] text-zinc-400 dark:text-zinc-500', `${item.recipient || '未指定收件人'} · ${item.status} · ${formatDate(item.created_at)}`));
			row.append(createElement('p', 'm-0 mt-1.5 line-clamp-5 whitespace-pre-wrap break-words font-mono text-[11px] leading-5 text-zinc-500 dark:text-zinc-400', item.body));
			outboxRoot.append(row);
		}
	};

	const loadComments = async () => {
		if (commentsRoot) commentsRoot.replaceChildren(emptyState('正在加载评论…'));
		const { comments } = await getAdminComments(currentFilter);
		renderComments(comments);
	};

	const loadDashboard = async () => {
		const [stats, comments, contacts, outbox] = await Promise.all([
			getAdminStats(), getAdminComments(currentFilter), getAdminContactMessages(), getAdminOutbox(),
		]);
		for (const key of ['total', 'pending', 'approved', 'rejected'] as const) {
			const target = root?.querySelector<HTMLElement>(`[data-admin-stat="${key}"]`);
			if (target) target.textContent = String(stats[key]);
		}
		setTabCount('comments', stats.total);
		setTabCount('messages', contacts.messages.length);
		renderComments(comments.comments);
		renderContacts(contacts.messages);
		renderOutbox(outbox.items);
	};

	const showFailure = (message: string) => {
		const error = root?.querySelector<HTMLElement>('[data-admin-auth-error]');
		if (error) error.textContent = message;
		authState?.classList.remove('hidden');
		if (authMessage) authMessage.textContent = '会话异常';
	};

	const initialize = async () => {
		const identity = await checkAdmin();
		if (!identity.isAdmin) return showFailure('无法访问管理台。请先使用被授予管理员权限的账户登录后重试。');
		authState?.classList.add('hidden');
		if (authMessage) authMessage.textContent = `已验证 @${identity.login ?? 'admin'}`;
		workspace?.classList.remove('hidden');
		subscriptionTab?.classList.toggle('hidden', !identity.permissions.manageSubscriptions);
		if (identity.permissions.manageSubscriptions) void loadSubscriptionSummary();
		try { await loadDashboard(); } catch { showFailure('管理数据加载失败。会话可能已过期，请重新登录后重试。'); }
		void loadArticles();
	};

	// —— 分区导航：文章 / 评论 / 消息 / 订阅 ——
	const tabs = root?.querySelectorAll<HTMLButtonElement>('[data-admin-tab]') ?? [];
	const switchTab = (active: string) => {
		tabs.forEach((tab) => tab.setAttribute('aria-pressed', String(tab.dataset.adminTab === active)));
		root?.querySelectorAll<HTMLElement>('[data-admin-panel]').forEach((panel) => {
			panel.classList.toggle('hidden', panel.dataset.adminPanel !== active);
		});
	};
	tabs.forEach((tab) => tab.addEventListener('click', () => switchTab(tab.dataset.adminTab || 'articles')));

	const loadSubscriptionSummary = async () => {
		const state = document.querySelector<HTMLElement>('[data-admin-subscription-state]');
		const expiry = document.querySelector<HTMLElement>('[data-admin-subscription-expiry]');
		try {
			const status = await getSubscriptionStatus();
			const unlocked = Boolean(status.unlocked);
			if (state) {
				state.textContent = unlocked ? '已解锁' : '未解锁';
				state.className = unlocked
					? 'text-[11px] font-semibold text-emerald-600 dark:text-emerald-400'
					: 'text-[11px] font-semibold text-zinc-400 dark:text-zinc-500';
			}
			if (expiry) expiry.textContent = unlocked && status.expiresAt ? `到期 ${formatDate(status.expiresAt)}` : '';
		} catch {
			if (state) state.textContent = '状态不可用';
		}
	};

	root?.querySelector('[data-admin-refresh]')?.addEventListener('click', async () => {
		try { await loadDashboard(); } catch { showFailure('刷新失败。请确认会话仍然有效。'); }
	});

	root?.querySelectorAll<HTMLButtonElement>('[data-admin-comment-filter]').forEach((button) => {
		button.addEventListener('click', async () => {
			currentFilter = (button.dataset.adminCommentFilter || 'all') as CommentFilter;
			root.querySelectorAll<HTMLButtonElement>('[data-admin-comment-filter]').forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
			try { await loadComments(); } catch { showFailure('评论加载失败。请确认会话仍然有效。'); }
		});
	});

	commentsRoot?.addEventListener('click', async (event) => {
		const button = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-admin-action]');
		const id = button?.dataset.commentId;
		if (!button || !id) return;
		const action = button.dataset.adminAction;
		if (action === 'delete' && !window.confirm('确认永久删除这条评论？')) return;
		button.disabled = true;
		try {
			if (action === 'approve') await approveComment(id);
			else if (action === 'reject') await rejectComment(id);
			else if (action === 'delete') await deleteComment(id);
			await Promise.all([loadComments(), getAdminStats().then((stats) => {
				for (const key of ['total', 'pending', 'approved', 'rejected'] as const) {
					const target = root.querySelector<HTMLElement>(`[data-admin-stat="${key}"]`);
					if (target) target.textContent = String(stats[key]);
				}
			})]);
		} catch { showFailure('评论操作失败。请确认会话仍然有效。'); }
		finally { button.disabled = false; }
	});

	// —— 文章管理（Phase 1：列表 / 查看 / 删除）——
	const articlesRoot = root?.querySelector<HTMLElement>('[data-admin-articles]');
	const articlesStatus = root?.querySelector<HTMLElement>('[data-admin-articles-status]');
	let pendingDeleteId: string | null = null;

	const setModalOpen = (id: string, open: boolean) => {
		const modal = document.getElementById(id);
		if (!modal) return;
		const content = modal.querySelector('.modal-content');
		if (open) {
			modal.classList.remove('opacity-0', 'invisible');
			modal.classList.add('opacity-100');
			content?.classList.remove('scale-95', 'opacity-0');
			content?.classList.add('scale-100', 'opacity-100');
			modal.setAttribute('aria-hidden', 'false');
		} else {
			modal.classList.add('opacity-0');
			modal.classList.remove('opacity-100');
			content?.classList.add('scale-95', 'opacity-0');
			content?.classList.remove('scale-100', 'opacity-100');
			setTimeout(() => modal.classList.add('invisible'), 200);
			modal.setAttribute('aria-hidden', 'true');
		}
	};
	document.querySelectorAll('#admin-article-view-modal [data-modal-close], #admin-article-delete-modal [data-modal-close]').forEach((button) => {
		button.addEventListener('click', () => {
			setModalOpen('admin-article-view-modal', false);
			setModalOpen('admin-article-delete-modal', false);
		});
	});

	const setArticlesStatus = (message: string) => {
		if (articlesStatus) articlesStatus.textContent = message;
	};

	// V2 高密度表格：草稿与已发布合并为一个表，文字式操作链接。
	let articleFilter: 'all' | 'draft' | 'published' = 'all';
	let cachedArticles: AdminArticle[] = [];
	let cachedDrafts: AdminArticleDraftSummary[] = [];

	const textActionButton = (label: string, action: string, id: string, tone: 'default' | 'danger' = 'default') => {
		const button = createElement('button', tone === 'danger'
			? 'text-[11px] text-rose-600 hover:text-rose-800 dark:text-rose-400 dark:hover:text-rose-300'
			: 'text-[11px] text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100', label);
		button.type = 'button';
		button.setAttribute('data-admin-article-action', action);
		button.dataset.articleId = id;
		return button;
	};
	const textActionLink = (label: string, href: string) => {
		const link = createElement('a', 'text-[11px] text-zinc-500 no-underline hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100', label);
		link.href = href;
		return link;
	};
	const setTabCount = (name: string, count: number | '') => {
		const target = root?.querySelector<HTMLElement>(`[data-admin-tab-count="${name}"]`);
		if (target) target.textContent = count === '' ? '' : String(count);
	};

	const renderTable = () => {
		if (!articlesRoot) return;
		articlesRoot.replaceChildren();

		// 按 group 把中英文配对稿合并为一个条目：一个入口管理一篇文章。
		const groups = new Map<string, AdminArticle[]>();
		for (const article of cachedArticles) {
			const key = article.group || article.id;
			const list = groups.get(key) ?? [];
			list.push(article);
			groups.set(key, list);
		}
		const published = [...groups.entries()]
			.map(([group, members]) => ({
				group,
				members,
				primary: members.find((member) => member.lang === 'cn') ?? members[0],
				hasMdx: members.some((member) => member.format === 'mdx'),
			}))
			.sort((a, b) => (b.primary.pubDate || '').localeCompare(a.primary.pubDate || ''));

		setTabCount('articles', groups.size);
		const counts = { all: cachedDrafts.length + published.length, draft: cachedDrafts.length, published: published.length };
		for (const key of ['all', 'draft', 'published'] as const) {
			const target = root?.querySelector<HTMLElement>(`[data-admin-filter-count="${key}"]`);
			if (target) target.textContent = String(counts[key]);
		}

		type Row =
			| { kind: 'draft'; draft: AdminArticleDraftSummary }
			| { kind: 'published'; entry: (typeof published)[number] };
		const rows: Row[] = [
			...(articleFilter !== 'published' ? cachedDrafts.map((draft) => ({ kind: 'draft' as const, draft })) : []),
			...(articleFilter !== 'draft' ? published.map((entry) => ({ kind: 'published' as const, entry })) : []),
		];
		if (!rows.length) {
			articlesRoot.append(emptyState(articleFilter === 'draft' ? '没有草稿。' : '没有文章。'));
			return;
		}

		const GRID = 'sm:grid sm:grid-cols-[minmax(0,1fr)_90px_110px_100px_130px] sm:items-center';
		rows.forEach((row, index) => {
			const zebra = index % 2 === 1 ? ' bg-white/70 dark:bg-zinc-900/50' : '';
			const container = createElement('div', `py-2.5 sm:py-2 ${GRID}${zebra}`);
			const topLine = createElement('div', 'flex items-center justify-between gap-3 sm:contents');
			// 显式 row-start-1：sparse 自动放置会把 col-start 靠后的单元格挤到下一行。
			const titleCell = createElement('div', 'flex min-w-0 items-center gap-2 sm:col-start-1 sm:row-start-1');
			const actionsCell = createElement('div', 'flex shrink-0 items-center gap-2.5 sm:col-start-5 sm:row-start-1');
			const langCell = createElement('div', 'hidden items-center gap-1.5 sm:col-start-2 sm:row-start-1 sm:flex');
			const catCell = createElement('div', 'hidden text-[11px] text-zinc-500 dark:text-zinc-400 sm:col-start-3 sm:row-start-1 sm:block');
			const dateCell = createElement('div', 'hidden whitespace-nowrap text-[11px] text-zinc-400 dark:text-zinc-500 sm:col-start-4 sm:row-start-1 sm:block');
			const mobileMeta = createElement('div', 'mt-1 text-[11px] text-zinc-400 dark:text-zinc-500 sm:hidden');

			const langBadge = (label: string, color: string) => createElement('span', `text-[10px] font-semibold ${color}`, label);

			if (row.kind === 'draft') {
				const { draft } = row;
				const draftDate = new Date(draft.updated_at);
				const isToday = draftDate.toDateString() === new Date().toDateString();
				const draftDateText = isToday
					? `更新于 ${draftDate.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })}`
					: draftDate.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
				titleCell.append(createElement('span', 'text-[10px] font-semibold text-amber-700 dark:text-amber-400', '草稿'));
				titleCell.append(createElement('span', 'truncate text-xs font-medium text-zinc-900 dark:text-zinc-100', draft.title || '（无标题）'));
				langCell.append(createElement('span', 'text-[11px] text-zinc-300 dark:text-zinc-600', '—'));
				catCell.textContent = '—';
				dateCell.textContent = draftDateText;
				mobileMeta.textContent = `${draft.slug} · ${draftDateText}`;
				actionsCell.append(textActionLink('继续编辑', `/admin/editor/?draft=${encodeURIComponent(draft.id)}`));
				actionsCell.append(textActionButton('删除', 'draft-delete', draft.id, 'danger'));
			} else {
				const { group, members, primary, hasMdx } = row.entry;
				const cn = members.find((member) => member.lang === 'cn');
				const en = members.find((member) => member.lang === 'en');
				if (members.some((member) => member.draft)) titleCell.append(createElement('span', 'text-[10px] font-semibold text-amber-700 dark:text-amber-400', '草稿'));
				titleCell.append(createElement('span', 'truncate text-xs font-medium text-zinc-900 dark:text-zinc-100', primary.title));
				titleCell.append(createElement('span', 'hidden truncate text-[11px] text-zinc-400 dark:text-zinc-500 lg:inline', group));
				langCell.append(langBadge('CN', 'text-emerald-600 dark:text-emerald-400'));
				langCell.append(en
					? langBadge('EN', 'text-zinc-400 dark:text-zinc-500')
					: createElement('span', 'text-[10px] text-zinc-300 dark:text-zinc-600', 'EN –'));
				if (hasMdx) langCell.append(langBadge('MDX', 'text-zinc-400 dark:text-zinc-500'));
				catCell.textContent = primary.category || '—';
				dateCell.textContent = primary.pubDate || '未设置日期';
				mobileMeta.textContent = `${en ? 'CN · EN' : 'CN · EN –'} · ${primary.category || '—'} · ${primary.pubDate || '未设置日期'}`;
				actionsCell.append(textActionButton('查看', 'view', primary.id));
				if (cn && cn.format === 'md') actionsCell.append(textActionLink('编辑', `/admin/editor/?article=${encodeURIComponent(cn.id)}`));
				if (primary.format === 'md' && !hasMdx) actionsCell.append(textActionButton('删除', 'delete', primary.id, 'danger'));
			}

			topLine.append(titleCell, actionsCell);
			container.append(topLine, langCell, catCell, dateCell, mobileMeta);
			articlesRoot.append(container);
		});
	};

	const loadArticles = async () => {
		if (articlesRoot) articlesRoot.replaceChildren(emptyState('正在同步仓库并加载文章…'));
		try {
			const [{ articles }, { drafts }] = await Promise.all([
				getAdminArticles(),
				getAdminArticleDrafts(),
			]);
			cachedArticles = articles;
			cachedDrafts = drafts;
			renderTable();
			setArticlesStatus(`${new Map(cachedArticles.map((article) => [article.group || article.id, article])).size} 组 · ${cachedArticles.length} 篇 · 同步于 ${new Date().toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' })}`);
		} catch {
			if (articlesRoot) articlesRoot.replaceChildren(emptyState('文章仓库在此主机不可用。'));
			setArticlesStatus('');
		}
	};

	root?.querySelectorAll<HTMLButtonElement>('[data-admin-article-filter]').forEach((button) => {
		button.addEventListener('click', () => {
			articleFilter = (button.dataset.adminArticleFilter || 'all') as typeof articleFilter;
			root.querySelectorAll<HTMLButtonElement>('[data-admin-article-filter]').forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
			renderTable();
		});
	});

	articlesRoot?.addEventListener('click', async (event) => {
		const button = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-admin-article-action]');
		const id = button?.dataset.articleId;
		if (!button || !id) return;
		const action = button.dataset.adminArticleAction;
		if (action === 'view') {
			button.disabled = true;
			try {
				const detail = await getAdminArticle(id);
				const title = document.querySelector<HTMLElement>('[data-admin-article-view-title]');
				const meta = document.querySelector<HTMLElement>('[data-admin-article-view-meta]');
				const source = document.querySelector<HTMLElement>('[data-admin-article-view-source]');
				if (title) title.textContent = detail.frontmatter.title || detail.id;
				if (meta) meta.textContent = `src/content/blog/${detail.file}`;
				if (source) source.textContent = detail.source;
				setModalOpen('admin-article-view-modal', true);
			} catch { setArticlesStatus('文章读取失败。'); }
			finally { button.disabled = false; }
			return;
		}
		if (action === 'draft-delete') {
			if (!window.confirm('删除这个草稿？此操作不影响已发布文章。')) return;
			button.disabled = true;
			try {
				await deleteAdminArticleDraft(id);
				cachedDrafts = cachedDrafts.filter((draft) => draft.id !== id);
				renderTable();
			} catch { setArticlesStatus('草稿删除失败。'); }
			finally { button.disabled = false; }
			return;
		}
		pendingDeleteId = id;
		const body = document.querySelector<HTMLElement>('[data-admin-article-delete-body]');
		const pair = document.querySelector<HTMLInputElement>('[data-admin-article-delete-pair]');
		if (body) body.textContent = `「${id}」将从 git 仓库删除并触发完整重新发布。`;
		// 列表按组管理配对稿，默认连同语言配对一起删除。
		if (pair) pair.checked = true;
		setModalOpen('admin-article-delete-modal', true);
	});

	const publishProgress = createPublishProgress();

	document.querySelector('[data-admin-article-delete-confirm]')?.addEventListener('click', async (event) => {
		const confirmButton = event.currentTarget as HTMLButtonElement;
		if (!pendingDeleteId) return;
		const pair = document.querySelector<HTMLInputElement>('[data-admin-article-delete-pair]')?.checked ?? false;
		confirmButton.disabled = true;
		setModalOpen('admin-article-delete-modal', false);
		publishProgress.show('正在删除并重新发布…');
		publishProgress.setStage('release', '服务器构建中，通常约 25 秒…');
		try {
			const result = await deleteAdminArticle(pendingDeleteId, pair);
			publishProgress.succeed(`已删除 ${result.deleted.length} 个文件并重新上线`);
			setArticlesStatus(`已删除，release ${result.release?.releaseId ?? '完成'}`);
			window.setTimeout(() => { publishProgress.hide(); }, 1600);
			await loadArticles();
		} catch (error) {
			publishProgress.fail(error instanceof Error ? error.message : '删除发布失败。');
		} finally {
			confirmButton.disabled = false;
			pendingDeleteId = null;
		}
	});

	root?.querySelector('[data-admin-articles-refresh]')?.addEventListener('click', () => { void loadArticles(); });

	void initialize();
	};

	document.addEventListener('astro:page-load', initAdminPage);
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initAdminPage, { once: true });
	} else {
		initAdminPage();
	}
</script>
