{
  "name": "xgwnje-homepage",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=22.12.0 <25",
    "npm": ">=10 <12"
  },
  "scripts": {
    "dev": "astro dev",
    "api:dev": "npm --prefix server start",
    "build": "astro build && node scripts/ensure-sitemap-xml.mjs",
    "content:check": "npm run test:content && npm run test:content-release && npm run build",
    "content:release:plan": "node scripts/publish-content.mjs --plan",
    "content:release:benchmark": "node scripts/publish-content.mjs --benchmark",
    "publish:full": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/publish-full.ps1",
    "clean:local": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/clean-local.ps1",
    "clean:local:all": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/clean-local.ps1 -IncludeReleaseArtifacts",
    "publish:content": "node scripts/publish-content.mjs",
    "indexnow": "node scripts/indexnow.mjs",
    "indexnow:sitemap": "node scripts/indexnow.mjs sitemap",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "astro check && tsc --noEmit",
    "test": "npm run test:unit && node scripts/run-checks.mjs",
    "test:unit": "tsx --test scripts/*.test.ts",
    "test:content": "node scripts/check-language-pairs.mjs",
    "test:content-release": "tsx --test scripts/content-release.test.ts scripts/content-delta.test.ts scripts/frontend-delta-release.test.ts scripts/asset-budget.test.ts",
    "test:brand": "node scripts/check-brand-assets.mjs",
    "test:ui-reuse": "node scripts/check-ui-reuse.mjs",
    "test:header": "node scripts/check-header-responsive.mjs",
    "test:links": "node scripts/check-links-page.mjs",
    "test:i18n": "node scripts/check-ui-i18n.mjs",
    "test:about": "node scripts/check-about-page.mjs",
		"test:admin": "node scripts/check-admin-page.mjs && node scripts/check-admin-subscriptions.mjs",
    "test:api": "npm --prefix server test",
    "verify": "npm test && npm run typecheck && npm run build && npm run test:api"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.1",
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.7",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tailwindcss/typography": "^0.5.20",
    "@types/hast": "^3.0.5",
    "@types/mdast": "^4.0.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4"
  }
}
