{
  "name": "astro-blog",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "api:dev": "node server/src/server.js",
    "build": "astro build && node scripts/ensure-sitemap-xml.mjs",
    "postbuild": "node scripts/postbuild-sitemap.mjs",
    "indexnow": "node scripts/indexnow.mjs",
    "indexnow:sitemap": "node scripts/indexnow.mjs sitemap",
    "preview": "astro preview",
    "astro": "astro",
    "test:content": "node scripts/check-language-pairs.mjs",
    "test:content-reset": "node scripts/check-content-reset.mjs",
    "test:brand": "node scripts/check-brand-assets.mjs",
    "test:header": "node scripts/check-header-responsive.mjs",
    "test:links": "node scripts/check-links-page.mjs",
    "test:i18n": "node scripts/check-ui-i18n.mjs",
    "test:api": "node --test server/test/*.test.js"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@tailwindcss/vite": "^4.1.18",
    "astro": "^5.17.1",
    "better-sqlite3": "^12.11.1",
    "busboy": "^1.6.0",
    "cookie": "^1.0.2",
    "express": "^5.2.1",
    "sharp": "^0.34.3",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19"
  }
}
